Options -Indexes
RewriteEngine On

# Redirections 301 — migration WordPress → Astro

# Pages obsolètes
Redirect 301 /projets/ /nos-projets/
Redirect 301 /david-manscour/ /equipe/
Redirect 301 /usecase-atmosphere/ /projet-pour-atmosphere-automatisation-des-flux-de-devis-et-de-fabrication-vers-un-crmaxonaut-trello/

# Pages à venir (temporaire)
Redirect 301 /outils/ /nos-projets/

# WordPress categories & tags
RedirectMatch 301 ^/category/(.*)$ /articles/
RedirectMatch 301 ^/tag/(.*)$ /articles/
