---
import BaseLayout from '../layouts/BaseLayout.astro';

const packs = [
  {
    id: 'automatisation',
    title: 'Automatisation & Workflows',
    tagline: 'Libérez-vous des tâches répétitives.',
    price: '1 500',
    popular: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="m11 18-3-3"/><circle cx="6" cy="18" r="3"/><path d="M6 9v6"/></svg>`,
    features: [
      { text: 'Audit de vos processus (session 2h)', detail: 'On identifie ensemble les tâches à fort potentiel d\'automatisation' },
      { text: 'Jusqu\'à 5 workflows n8n ou Make', detail: 'Flux automatisés connectés à vos outils existants' },
      { text: 'Connexions API (CRM, email, Slack, Notion…)', detail: 'Synchronisation de vos données sans intervention manuelle' },
      { text: 'Alertes & notifications automatiques', detail: 'Votre équipe est notifiée au bon moment, sur le bon canal' },
      { text: 'Documentation technique complète', detail: 'Maintenez et faites évoluer vos workflows en autonomie' },
      { text: '1 mois de support inclus', detail: 'Ajustements et corrections sans surcoût pendant 30 jours' },
    ],
    results: [
      { stat: '-80%', label: 'de temps sur les tâches manuelles' },
      { stat: '6 sem.', label: 'ROI moyen constaté' },
    ],
  },
  {
    id: 'agent-ia',
    title: 'Agent Vocal ou Chatbot IA',
    tagline: 'Un agent IA disponible 24/7 pour vos clients.',
    price: '2 500',
    popular: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.82 5.82l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>`,
    features: [
      { text: 'Voice bot (VAPI / Retell AI) ou chatbot web', detail: 'Choix de la technologie adaptée à votre cas d\'usage' },
      { text: 'Scénarios de conversation sur-mesure', detail: 'Scripts et arbres de décision calqués sur votre process commercial' },
      { text: 'Qualification et scoring des leads', detail: 'L\'agent évalue la maturité d\'achat et priorise les prospects chauds' },
      { text: 'Intégration CRM (HubSpot, Axonaut…)', detail: 'Chaque interaction enrichit automatiquement votre base client' },
      { text: 'Rapport de performance hebdomadaire', detail: 'Taux de succès, objections fréquentes, points d\'amélioration' },
      { text: '2 mois de support inclus', detail: 'Optimisation continue des scripts et des flux post-livraison' },
    ],
    results: [
      { stat: '24/7', label: 'sans ressource humaine supplémentaire' },
      { stat: '+35%', label: 'de leads mieux qualifiés' },
    ],
  },
  {
    id: 'solution-complete',
    title: 'Solution IA Sur-Mesure',
    tagline: 'Une infrastructure IA complète, bout-en-bout.',
    price: '5 000',
    popular: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>`,
    features: [
      { text: 'Analyse métier approfondie (ateliers dédiés)', detail: 'Cartographie complète de vos processus et identification des ROI cibles' },
      { text: 'Agent IA + automatisations n8n orchestrées', detail: 'Voice bot, chatbot ou agent autonome combiné à des workflows complexes' },
      { text: 'Base de connaissances RAG personnalisée', detail: 'L\'IA est entraînée sur vos documents, produits et historiques clients' },
      { text: 'Intégrations multi-outils (CRM, ERP, API)', detail: 'Votre écosystème complet synchronisé en temps réel' },
      { text: 'Dashboard de performance sur-mesure', detail: 'Pilotez vos KPIs IA directement depuis votre interface métier' },
      { text: '3 mois de support & évolutions inclus', detail: 'Votre système évolue avec votre activité sans coût additionnel' },
    ],
    results: [
      { stat: '-70%', label: 'de coûts opérationnels' },
      { stat: '100%', label: 'propriétaire du code livré' },
    ],
  },
];

const appPack = {
  id: 'webapp-ia',
  title: 'Application Web sur-mesure',
  tagline: 'Un produit digital complet, avec l\'IA au cœur.',
  price: '8 000',
  icon: `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="m9 8 2 2-2 2"/><path d="M13 12h2"/></svg>`,
  features: [
    { text: 'Conception UX & maquettes Figma', detail: 'Parcours utilisateurs, wireframes et design system avant le moindre code' },
    { text: 'Frontend React / Next.js', detail: 'Interface moderne, responsive et performante (Core Web Vitals optimisés)' },
    { text: 'Backend, API & base de données', detail: 'Architecture robuste, sécurisée, scalable selon votre charge' },
    { text: 'Authentification & gestion des rôles', detail: 'Accès multi-profils, SSO, permissions granulaires' },
    { text: 'Features IA intégrées sur-mesure', detail: 'Chatbot, voice assistant, RAG, génération de contenu, scoring IA…' },
    { text: 'Déploiement & CI/CD inclus', detail: 'Mise en production sur votre infrastructure + pipeline automatisé' },
    { text: '6 mois de support & évolutions', detail: 'Votre produit évolue avec vos retours utilisateurs sans coût additionnel' },
  ],
  results: [
    { stat: '100%', label: 'propriétaire du produit' },
    { stat: '8 sem.', label: 'livraison moyenne' },
    { stat: '0€', label: 'de licence logicielle' },
  ],
};

const aiAppFeatures = [
  {
    title: 'Chatbot & assistant IA',
    description: 'Un assistant conversationnel intégré à votre app, entraîné sur vos données métier.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Voice assistant intégré',
    description: 'Interaction vocale dans votre interface — VAPI ou Retell AI branché directement sur votre app.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`,
  },
  {
    title: 'Recherche sémantique (RAG)',
    description: 'Moteur de recherche IA dans vos documents, emails ou historiques — résultats en langage naturel.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
  },
  {
    title: 'Génération de contenu',
    description: 'Rédaction automatique, résumé, reformulation — l\'IA produit du contenu utile directement dans votre interface.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>`,
  },
  {
    title: 'Scoring & recommandations',
    description: 'Modèles de scoring personnalisés pour prioriser leads, tâches ou opportunités automatiquement.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
  },
  {
    title: 'Analyse de documents',
    description: 'Extraction automatique de données depuis PDF, images ou emails — structurées et exploitables.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
  },
];

const solutions = [
  {
    title: 'Voice Bots IA',
    description: 'Agents vocaux VAPI & Retell AI pour qualifier vos leads, prendre des rendez-vous et traiter vos appels entrants 24h/24.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.82 5.82l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>`,
  },
  {
    title: 'Automatisation n8n',
    description: 'Workflows sur-mesure qui connectent vos outils, éliminent les saisies manuelles et déclenchent les bonnes actions au bon moment.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="m11 18-3-3"/><circle cx="6" cy="18" r="3"/><path d="M6 9v6"/></svg>`,
  },
  {
    title: 'Agents RAG & Chatbots',
    description: 'Chatbots entraînés sur votre base de connaissances métier pour répondre à vos clients et collaborateurs avec précision.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
];

const faqs = [
  {
    q: 'Les prix incluent-ils la maintenance ?',
    a: 'Chaque pack inclut une période de support (1 à 3 mois selon le pack). Au-delà, nous proposons des contrats de maintenance mensuelle à partir de 300€ HT/mois.',
  },
  {
    q: 'Combien de temps dure un projet ?',
    a: 'Un pack Automatisation est livré en 2 à 3 semaines. Un Agent Vocal en 3 à 5 semaines. Une Solution Sur-Mesure complexe, entre 6 et 12 semaines selon le périmètre.',
  },
  {
    q: 'On reste propriétaire du code ?',
    a: 'Oui, à 100%. Vous recevez l\'intégralité du code source, des workflows et des modèles. Aucune dépendance à notre infrastructure.',
  },
  {
    q: 'Peut-on adapter le pack à nos besoins ?',
    a: 'Absolument. Les prix indiqués sont des bases. Nous construisons un devis sur-mesure après un premier appel de découverte gratuit.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Tarifs agents IA, voice bots et automatisation"
  description="Découvrez nos packs d'automatisation IA, voice bots et agents conversationnels. Prix à partir de 1 500€ HT. Devis personnalisé sous 48h."
  pathname="/tarifs/"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <main class="pt-28 pb-24">

    <!-- Hero -->
    <header class="max-w-7xl mx-auto px-6 md:px-10 mb-20 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-50 border border-blue-100 mb-6">
        <span class="text-primary text-[10px] font-bold tracking-widest uppercase">Prestations & Tarifs</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-6 leading-[1.05]">
        Des agents IA et automatisations<br class="hidden md:block" /> au prix juste.
      </h1>
      <p class="max-w-2xl mx-auto text-slate-500 text-lg md:text-xl leading-relaxed">
        Voice bot, chatbot IA, automatisation CRM ou agent conversationnel — chaque prestation est calibrée pour livrer un ROI mesurable. Devis sur-mesure après un premier appel gratuit.
      </p>
    </header>

    <!-- Pricing grid -->
    <section class="max-w-7xl mx-auto px-6 md:px-10 mb-32" aria-labelledby="pricing-heading">
      <h2 id="pricing-heading" class="sr-only">Nos packs agents IA, voice bot et automatisation</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">

        {packs.map((pack) => (
          <div class={`group relative flex flex-col h-full rounded-3xl bg-white border transition-all duration-300 ${
            pack.popular
              ? 'border-2 border-primary shadow-[0_20px_60px_rgba(37,99,235,0.15)] md:scale-105 md:z-10'
              : 'border-slate-100 shadow-[0_8px_30px_rgba(13,28,47,0.05)] hover:shadow-[0_20px_40px_rgba(13,28,47,0.08)]'
          }`}>

            {pack.popular && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white px-5 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase shadow-lg">
                Le plus choisi
              </div>
            )}

            <div class="p-8 md:p-10 flex flex-col flex-1">

              <!-- Icon + title -->
              <div class="mb-8">
                <div class="text-primary mb-5">
                  <Fragment set:html={pack.icon} />
                </div>
                <h3 class="text-2xl font-extrabold text-slate-900 mb-2 tracking-tight">{pack.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{pack.tagline}</p>
              </div>

              <!-- Features -->
              <ul class="space-y-5 mb-8 flex-1">
                {pack.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <div>
                      <p class="text-sm font-semibold text-slate-800">{f.text}</p>
                      <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">{f.detail}</p>
                    </div>
                  </li>
                ))}
              </ul>

              <!-- Results -->
              <div class="grid grid-cols-2 gap-3 mb-8 p-4 bg-slate-50 rounded-2xl">
                {pack.results.map((r) => (
                  <div class="text-center">
                    <p class="text-xl font-black text-primary">{r.stat}</p>
                    <p class="text-[11px] text-slate-500 leading-tight mt-0.5">{r.label}</p>
                  </div>
                ))}
              </div>

              <!-- Price + CTA -->
              <div class="pt-8 border-t border-slate-100">
                <div class="flex items-baseline gap-2 mb-6">
                  <span class="text-xs text-slate-500 font-medium">À partir de</span>
                  <span class="text-4xl font-black text-primary">{pack.price}€</span>
                  <span class="text-slate-500 text-sm">HT</span>
                </div>
                <a
                  href="/contact/"
                  class={`flex items-center justify-center gap-2 w-full py-4 min-h-[52px] rounded-2xl font-bold text-sm transition-all duration-200 ${
                    pack.popular
                      ? 'bg-primary text-white shadow-[0_4px_20px_rgba(37,99,235,0.35)] hover:bg-blue-700 hover:scale-[1.02] active:scale-95'
                      : 'bg-slate-100 text-slate-800 group-hover:bg-primary group-hover:text-white'
                  }`}
                >
                  Demander un devis
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>

            </div>
          </div>
        ))}

      </div>

      <p class="text-center text-sm text-slate-500 mt-10">
        Tous les prix sont HT. TVA applicable selon votre situation. Paiement en 2 ou 3 fois disponible.
      </p>
    </section>

    <!-- Application Web IA — pack full-width -->
    <section class="max-w-7xl mx-auto px-6 md:px-10 mb-12" aria-labelledby="webapp-heading">
      <div class="relative overflow-hidden rounded-3xl bg-slate-900 border border-slate-800 shadow-[0_30px_80px_rgba(13,28,47,0.2)]">
        <!-- Decorative blobs -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4 pointer-events-none" aria-hidden="true"></div>

        <div class="relative z-10 p-6 sm:p-10 md:p-14">
          <!-- Header -->
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 md:gap-8 mb-10">
            <!-- Icon + title + subtitle + price (mobile: stacked left) -->
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:gap-5">
              <div class="text-primary bg-blue-500/10 p-4 rounded-2xl self-start shrink-0">
                <Fragment set:html={appPack.icon} />
              </div>
              <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 border border-primary/30 mb-3">
                  <span class="text-blue-300 text-[10px] font-bold tracking-widest uppercase">Nouveau</span>
                </div>
                <h2 id="webapp-heading" class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-white tracking-tight mb-2">{appPack.title}</h2>
                <p class="text-slate-400 text-base leading-relaxed max-w-xl">{appPack.tagline}</p>
                <!-- Price — mobile only -->
                <div class="mt-4 md:hidden">
                  <p class="text-slate-500 text-xs font-medium mb-1">À partir de</p>
                  <p class="text-4xl font-black text-white">{appPack.price}<span class="text-xl text-slate-400 font-bold">€</span> <span class="text-slate-500 text-sm font-medium">HT</span></p>
                </div>
              </div>
            </div>
            <!-- Price — desktop only -->
            <div class="hidden md:block shrink-0 text-right">
              <p class="text-slate-500 text-xs font-medium mb-1">À partir de</p>
              <p class="text-5xl font-black text-white">{appPack.price}<span class="text-2xl text-slate-400 font-bold">€</span></p>
              <p class="text-slate-500 text-sm mt-1">HT</p>
            </div>
          </div>

          <!-- Features + Results -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
            <!-- Features list — span 2 cols -->
            <ul class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
              {appPack.features.map((f) => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-1" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <div>
                    <p class="text-sm font-semibold text-white">{f.text}</p>
                    <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">{f.detail}</p>
                  </div>
                </li>
              ))}
            </ul>

            <!-- Results -->
            <div class="flex flex-col gap-4 justify-center">
              {appPack.results.map((r) => (
                <div class="bg-white/5 border border-white/10 rounded-2xl p-5 text-center">
                  <p class="text-3xl font-black text-primary mb-1">{r.stat}</p>
                  <p class="text-xs text-slate-400 leading-tight">{r.label}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact/"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 min-h-[52px] bg-primary hover:bg-blue-700 text-white rounded-2xl font-bold text-sm shadow-[0_4px_20px_rgba(37,99,235,0.4)] hover:scale-[1.02] active:scale-95 transition-all duration-200"
            >
              Discuter de mon projet d'automatisation
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="/nos-projets/"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 min-h-[52px] bg-white/10 hover:bg-white/15 border border-white/10 text-white rounded-2xl font-bold text-sm transition-all duration-200"
            >
              Voir nos réalisations en agents IA
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features IA intégrables dans une app -->
    <section class="bg-[#f0f4ff] py-24 mb-32" aria-labelledby="ai-features-heading">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="max-w-2xl mb-14">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white border border-blue-100 mb-6">
            <span class="text-primary text-[10px] font-bold tracking-widest uppercase">Features IA</span>
          </div>
          <h2 id="ai-features-heading" class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
            Fonctionnalités IA à intégrer dans votre application
          </h2>
          <p class="text-slate-500 leading-relaxed">
            Chatbot IA, agent vocal, RAG sur vos données, automatisation de workflows — des briques IA natives conçues pour s'intégrer dans votre produit, pas plaquées dessus.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {aiAppFeatures.map((f) => (
            <div class="bg-white p-7 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
              <div class="bg-blue-50 text-primary p-3 rounded-xl w-fit mb-5">
                <Fragment set:html={f.icon} />
              </div>
              <h3 class="font-extrabold text-slate-900 text-base mb-2">{f.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">{f.description}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 p-6 bg-white rounded-2xl border border-slate-100 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-5">
          <p class="text-slate-600 text-sm leading-relaxed max-w-xl">
            <span class="font-bold text-slate-900">Ces features peuvent être combinées</span> dans un seul produit. On construit l'architecture pour que chaque brique IA s'intègre sans friction avec les autres.
          </p>
          <a
            href="/contact/"
            class="shrink-0 inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-xl font-bold text-sm hover:bg-blue-700 transition-colors"
          >
            En discuter
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Ce qui est inclus dans tous les packs -->
    <section class="bg-slate-50 py-24 mb-32" aria-labelledby="solutions-heading">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
          <div class="max-w-xl">
            <h2 id="solutions-heading" class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
              Inclus dans chaque prestation
            </h2>
            <p class="text-slate-500 leading-relaxed">
              Quel que soit le pack choisi, vous bénéficiez des mêmes standards de qualité et de livraison.
            </p>
          </div>
          <a href="/nos-projets/" class="inline-flex items-center gap-2 text-primary font-bold text-sm hover:gap-4 transition-all duration-300 shrink-0">
            Voir nos réalisations en agents IA
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Garanties universelles -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
          {[
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`, title: 'Code ownership', text: '100% du code et des workflows vous appartient à la livraison.' },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`, title: 'Livraison en sprints', text: 'Démos hebdomadaires — vous voyez l\'avancement à chaque étape.' },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`, title: 'ROI garanti', text: 'Si on ne voit pas de ROI potentiel, on vous le dit avant de démarrer.' },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 9 5 12V9l-5 12"/><path d="M9 9h7"/></svg>`, title: 'Documentation complète', text: 'Chaque projet est livré avec sa documentation technique pour votre équipe.' },
          ].map((item) => (
            <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
              <div class="text-primary mb-4">
                <Fragment set:html={item.icon} />
              </div>
              <h4 class="font-extrabold text-slate-900 text-sm mb-2">{item.title}</h4>
              <p class="text-slate-500 text-xs leading-relaxed">{item.text}</p>
            </div>
          ))}
        </div>

        <!-- Solutions techniques -->
        <h3 class="text-xl font-extrabold text-slate-900 mb-6 tracking-tight">Technologies maîtrisées</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {solutions.map((s) => (
            <div class="bg-white p-8 rounded-2xl flex items-start gap-5 border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-300">
              <div class="bg-blue-50 p-3.5 rounded-xl text-primary shrink-0">
                <Fragment set:html={s.icon} />
              </div>
              <div>
                <h4 class="font-extrabold text-slate-900 text-base mb-2">{s.title}</h4>
                <p class="text-sm text-slate-500 leading-relaxed">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto px-6 md:px-10 mb-32" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-3xl font-extrabold text-slate-900 tracking-tight mb-10 text-center">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm">
            <summary class="flex justify-between items-center px-7 py-5 cursor-pointer font-semibold text-slate-900 text-sm hover:bg-slate-50 transition-colors list-none">
              {faq.q}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="px-7 pb-6 text-sm text-slate-500 leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-5xl mx-auto px-6 md:px-10" aria-labelledby="cta-tarifs-heading">
      <div class="relative overflow-hidden bg-gradient-to-br from-blue-700 via-blue-800 to-blue-900 rounded-[3rem] p-12 md:p-20 text-center text-white">
        <div class="absolute inset-0 opacity-[0.07] dot-pattern-lg" aria-hidden="true"></div>
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-600/40 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2" aria-hidden="true"></div>
        <div class="relative z-10">
          <h2 id="cta-tarifs-heading" class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 leading-tight">
            Prêt à transformer<br class="hidden md:block" /> votre entreprise ?
          </h2>
          <p class="text-blue-100 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
            Discutez de votre projet avec un expert et recevez une estimation personnalisée sous 48h. Premier appel gratuit, sans engagement.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/contact/"
              class="bg-white text-primary px-10 py-5 rounded-2xl font-extrabold text-base shadow-xl hover:scale-[1.03] active:scale-95 transition-all duration-200"
            >
              Réserver un appel gratuit
            </a>
            <a
              href="/nos-projets/"
              class="bg-white/10 border border-white/20 backdrop-blur-sm text-white px-10 py-5 rounded-2xl font-bold text-base hover:bg-white/20 transition-all duration-200"
            >
              Voir nos réalisations en agents IA
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
