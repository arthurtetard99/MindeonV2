---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/helpers';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(sorted.flatMap(a => a.data.tags ?? []))].sort();

// Cycle through 3 visual styles
const styles = [
  {
    bannerClass: 'article-banner-blue',
    tagColor: 'text-blue-700 bg-blue-50',
    linkColor: 'text-blue-700',
  },
  {
    bannerClass: 'article-banner-violet',
    tagColor: 'text-violet-700 bg-violet-50',
    linkColor: 'text-violet-700',
  },
  {
    bannerClass: 'article-banner-slate',
    tagColor: 'text-slate-600 bg-slate-100',
    linkColor: 'text-slate-600',
  },
];

// Pick icon SVG based on tags
function getIcon(tags: string[]): string {
  const all = (tags ?? []).map(t => t.toLowerCase()).join(' ');
  if (all.includes('voice') || all.includes('vapi') || all.includes('retell'))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.82 5.82l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>`;
  if (all.includes('rag') || all.includes('chatbot') || all.includes('agent'))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>`;
  if (all.includes('n8n') || all.includes('make') || all.includes('zapier') || all.includes('workflow'))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="m11 18-3-3"/><circle cx="6" cy="18" r="3"/><path d="M6 9v6"/></svg>`;
  if (all.includes('roi') || all.includes('calcul') || all.includes('stratégi'))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`;
  if (all.includes('mcp') || all.includes('gemini') || all.includes('gpt'))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;
  // default
  return `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`;
}
---

<BaseLayout
  title="Blog IA - Guides et tendances automatisation | Mindeon.ai"
  description="Analyses, comparatifs et guides pratiques sur l'IA, l'automatisation et les agents intelligents pour les entreprises."
  pathname="/articles/"
>
  <main class="pt-28 pb-20">

    <!-- Hero -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mb-20">
      <div class="max-w-3xl">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">Editorial Intelligence</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 tracking-tight mb-6 leading-[1.1]">
          Nos analyses IA
        </h1>
        <p class="text-xl text-slate-500 leading-relaxed">
          Décryptage des avancées technologiques, veille stratégique et guides pratiques pour naviguer dans l'ère de l'intelligence artificielle générative.
        </p>
      </div>
    </section>

    <!-- Search -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mb-6">
      <div class="relative max-w-xl">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          id="article-search"
          type="search"
          placeholder="Rechercher un article..."
          autocomplete="off"
          class="w-full pl-11 pr-10 py-3 rounded-xl border border-slate-200 bg-white text-sm text-slate-800 placeholder:text-slate-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
          aria-label="Rechercher un article"
        />
        <button
          id="search-clear"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 hidden p-1"
          aria-label="Effacer la recherche"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </section>

    <!-- Tag filters -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mb-10">
      <div class="flex flex-wrap gap-2" id="tag-filters" role="group" aria-label="Filtrer par thème">
        <button
          data-tag="all"
          class="tag-btn active px-4 py-2.5 rounded-full text-xs font-bold border transition-all duration-200 bg-primary text-white border-primary min-h-[40px]"
        >
          Tous
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn px-4 py-2.5 rounded-full text-xs font-bold border border-slate-200 text-slate-600 hover:border-primary hover:bg-primary hover:text-white transition-all duration-200 bg-white min-h-[40px]"
          >
            {tag}
          </button>
        ))}
      </div>
    </section>

    <!-- Articles grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="articles-grid">
        {sorted.map((article, i) => {
          const s = styles[i % 3];
          const icon = getIcon(article.data.tags ?? []);
          const tags = article.data.tags ?? ['IA'];
          return (
            <a
              href={`/${article.slug}/`}
              class="article-card group flex flex-col bg-white rounded-[1.5rem] overflow-hidden transition-all duration-300 hover:-translate-y-1 shadow-[0_4px_24px_rgba(13,28,47,0.06)] hover:shadow-[0_12px_40px_rgba(13,28,47,0.12)]"
              data-tags={JSON.stringify(article.data.tags ?? [])}
              data-title={article.data.title.toLowerCase()}
              aria-label={article.data.title}
            >
              <!-- Banner -->
              <div class={`h-48 relative overflow-hidden flex items-center justify-center ${s.bannerClass}`}>
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                <Fragment set:html={icon} />
              </div>

              <!-- Body -->
              <div class="p-8 flex flex-col flex-1">
                <div class="mb-4 flex flex-wrap gap-1.5">
                  {tags.map(t => (
                    <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full ${s.tagColor}`}>
                      {t}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl font-extrabold text-slate-900 mb-4 leading-snug group-hover:text-primary transition-colors line-clamp-2">
                  {article.data.title}
                </h2>
                <p class="text-sm text-slate-500 leading-relaxed line-clamp-3 mb-8 flex-1">
                  {article.data.description}
                </p>
                <div class="mt-auto">
                  <span class={`inline-flex items-center gap-1 font-bold text-sm ${s.linkColor} group-hover:gap-3 transition-all duration-300`}>
                    Lire l'article
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>

            </a>
          );
        })}
      </div>
    </section>

    <!-- Maillage interne -->
    <section class="max-w-7xl mx-auto px-8 mt-20 pt-16 border-t border-slate-100">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a href="/nos-projets/" class="group flex items-center gap-4 p-6 bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-blue-50 text-primary p-3 rounded-xl shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
          </div>
          <div>
            <p class="font-extrabold text-slate-900 text-sm group-hover:text-primary transition-colors">Nos réalisations</p>
            <p class="text-xs text-slate-500 mt-0.5">15+ projets livrés</p>
          </div>
        </a>
        <a href="/tarifs/" class="group flex items-center gap-4 p-6 bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-blue-50 text-primary p-3 rounded-xl shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div>
            <p class="font-extrabold text-slate-900 text-sm group-hover:text-primary transition-colors">Tarifs & packs</p>
            <p class="text-xs text-slate-500 mt-0.5">À partir de 1 500€ HT</p>
          </div>
        </a>
        <a href="/contact/" class="group flex items-center gap-4 p-6 bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-blue-50 text-primary p-3 rounded-xl shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.82 5.82l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>
          </div>
          <div>
            <p class="font-extrabold text-slate-900 text-sm group-hover:text-primary transition-colors">Consultation gratuite</p>
            <p class="text-xs text-slate-500 mt-0.5">30 min, sans engagement</p>
          </div>
        </a>
      </div>
    </section>

  </main>

  <script>
    const buttons     = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const cards       = document.querySelectorAll<HTMLElement>('.article-card');
    const searchInput = document.getElementById('article-search') as HTMLInputElement | null;
    const clearBtn    = document.getElementById('search-clear') as HTMLButtonElement | null;

    let activeTag   = 'all';
    let searchQuery = '';

    function applyFilters() {
      cards.forEach(card => {
        let tags: string[] = [];
        try { tags = JSON.parse(card.dataset.tags ?? '[]'); } catch {}
        const title = card.dataset.title ?? '';

        const matchTag    = activeTag === 'all' || tags.includes(activeTag);
        const matchSearch = searchQuery === '' ||
          title.includes(searchQuery) ||
          tags.some(t => t.toLowerCase().includes(searchQuery));

        card.style.display = matchTag && matchSearch ? '' : 'none';
      });
    }

    // Tag buttons
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTag = btn.dataset.tag ?? 'all';
        buttons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary', 'active');
          b.classList.add('border-slate-200', 'text-slate-600', 'bg-white');
        });
        btn.classList.add('bg-primary', 'text-white', 'border-primary', 'active');
        btn.classList.remove('border-slate-200', 'text-slate-600', 'bg-white');
        applyFilters();
      });
    });

    // Search input
    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      if (clearBtn) clearBtn.classList.toggle('hidden', searchQuery === '');
      applyFilters();
    });

    // Clear button
    clearBtn?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      searchQuery = '';
      clearBtn.classList.add('hidden');
      applyFilters();
    });
  </script>
</BaseLayout>
