---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Badge from '../components/ui/Badge.astro';
import { formatDate } from '../utils/helpers';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog IA — Actualités et tendances de l'intelligence artificielle"
  description="Analyses, comparatifs et guides pratiques sur l'IA, l'automatisation et les agents intelligents pour les entreprises."
  pathname="/articles/"
>
  <!-- Header -->
  <section class="bg-slate-50 border-b border-slate-200 pt-16 pb-20 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <Badge>Blog</Badge>
      <h1 class="mt-4 text-5xl font-extrabold text-slate-900 leading-tight tracking-tight mb-4">
        Nos analyses IA
      </h1>
      <p class="text-xl text-slate-600">
        Veille technologique, comparatifs d'outils et guides pratiques pour comprendre l'IA.
      </p>
    </div>
  </section>

  <!-- Articles grid -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sorted.map(article => (
          <article class="relative group bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-300">
            <!-- Color accent -->
            <div class="h-1.5 bg-gradient-to-r from-secondary to-primary"></div>
            <div class="p-8">
              {article.data.tags && article.data.tags[0] && (
                <span class="text-xs font-bold text-secondary uppercase tracking-widest">{article.data.tags[0]}</span>
              )}
              <h2 class="text-lg font-bold text-slate-900 leading-tight mt-3 mb-3 group-hover:text-primary transition-colors">
                <a href={`/${article.slug}/`} class="after:absolute after:inset-0">
                  {article.data.title}
                </a>
              </h2>
              <p class="text-sm text-slate-600 leading-relaxed line-clamp-3 mb-6">
                {article.data.description}
              </p>
              <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                <time class="text-xs text-slate-400" datetime={article.data.date.toISOString()}>
                  {formatDate(article.data.date)}
                </time>
                <span class="text-primary text-xs font-semibold">Lire →</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
