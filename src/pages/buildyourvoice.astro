        transfer: false, transferCondition: '', transferMessage: '',
        mustDo: "Confirmer le créneau choisi clairement\nVérifier le numéro de téléphone de rappel\nRécapituler le RDV en fin d'appel",
        mustNot: "Proposer des créneaux déjà pris\nOublier de récapituler le RDV en fin d'appel",
        products: '', faq: '',
      },
      marie: {
        name: 'Marie', role: 'Agente rétention & SAV', company: '', industry: 'E-commerce / Services', signature: 'Merci pour votre fidélité.',
        tones: ['empathetic'], traits: ['patient', 'calm', 'attentive'], humor: 'subtle', style: 'balanced',
        features: ['retention', 'objections', 'inform', 'support'],
        objectives: ["Comprendre la raison de l'insatisfaction", "Proposer une solution ou compensation adaptée", "Fidéliser et maintenir la relation client"],
        dataFields: ['name', 'email', 'reason', 'needs'],
        transfer: true, transferCondition: "Client souhaitant résilier malgré une offre de rétention", transferMessage: 'Je vous transfère vers notre service spécialisé.',
        mustDo: "Remercier le client pour sa fidélité\nRechercher la cause profonde de l'insatisfaction\nProposer une offre ou solution concrète",
        mustNot: "Laisser le client raccrocher sans avoir tenté une rétention\nInventer une offre non approuvée",
        products: '', faq: '',
      },
    };

    const state = {
      selectedTone: '',
      selectedTraits: [],
      selectedHumor: 'none',
      selectedStyle: 'concise',
      selectedFeatures: [],
      selectedDataFields: [],
      transferEnabled: false,
      tools: [],
      objectives: ['', ''],
    };

    function chipClass(active) {
      return active
        ? 'byv-chip px-4 py-2 rounded-full text-sm font-medium border border-primary bg-primary/10 text-primary transition-colors'
        : 'byv-chip px-4 py-2 rounded-full text-sm font-medium border border-slate-200 text-slate-600 hover:border-primary hover:text-primary transition-colors';
    }

    function renderChips(containerId, items, type) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.innerHTML = '';
      items.forEach(item => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.dataset.type = type;
        btn.dataset.value = item.id;
        btn.textContent = item.label;
        btn.className = chipClass(false);
        btn.addEventListener('click', () => handleChipClick(btn, type));
        container.appendChild(btn);
      });
    }

    function handleChipClick(btn, type) {
      const value = btn.dataset.value;
      const isSingle = type === 'tone' || type === 'humor' || type === 'style';

      if (isSingle) {
        document.querySelectorAll('[data-type="' + type + '"]').forEach(b => { b.className = chipClass(false); });
        btn.className = chipClass(true);
        if (type === 'tone') state.selectedTone = value;
        else if (type === 'humor') state.selectedHumor = value;
        else if (type === 'style') state.selectedStyle = value;
      } else {
        const isActive = btn.className.includes('bg-primary');
        btn.className = chipClass(!isActive);
        const arr = type === 'traits' ? state.selectedTraits : type === 'features' ? state.selectedFeatures : state.selectedDataFields;
        if (isActive) {
          const idx = arr.indexOf(value);
          if (idx > -1) arr.splice(idx, 1);
        } else {
          arr.push(value);
        }
      }
    }

    function activateChips(containerId, values) {
      const valArray = Array.isArray(values) ? values : [values];
      document.querySelectorAll('#' + containerId + ' .byv-chip').forEach(btn => {
        btn.className = chipClass(valArray.includes(btn.dataset.value));
      });
    }

    function renderObjectives() {
      const list = document.getElementById('objectives-list');
      if (!list) return;
      list.innerHTML = '';
      state.objectives.forEach((val, i) => {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2';
        const numSpan = document.createElement('span');
        numSpan.className = 'w-6 h-6 rounded-full bg-slate-100 text-slate-500 text-xs font-bold flex items-center justify-center shrink-0';
        numSpan.textContent = String(i + 1);
        const input = document.createElement('input');
        input.type = 'text';
        input.value = val;
        input.placeholder = 'Ex : Qualifier les prospects entrants...';
        input.className = 'flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors';
        input.addEventListener('input', () => { state.objectives[i] = input.value; });
        row.appendChild(numSpan);
        row.appendChild(input);
        if (state.objectives.length > 1) {
          const del = document.createElement('button');
          del.type = 'button';
          del.className = 'text-slate-400 hover:text-red-500 transition-colors p-1 shrink-0';
          del.setAttribute('aria-label', 'Supprimer');
          del.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
          del.addEventListener('click', () => { state.objectives.splice(i, 1); renderObjectives(); });
          row.appendChild(del);
        }
        list.appendChild(row);
      });
      const addBtn = document.getElementById('add-objective-btn');
      if (addBtn) addBtn.style.display = state.objectives.length >= 5 ? 'none' : 'flex';
    }

    function renderTools() {
      const list = document.getElementById('tools-list');
      if (!list) return;
      list.innerHTML = '';
      state.tools.forEach((tool, i) => {
        const row = document.createElement('div');
        row.className = 'bg-slate-50 rounded-xl p-4 border border-slate-200';
        const header = document.createElement('div');
        header.className = 'flex items-center justify-between mb-3';
        header.innerHTML = '<span class="text-sm font-semibold text-slate-700">Outil ' + (i + 1) + '</span>';
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'text-slate-400 hover:text-red-500 transition-colors text-xs';
        del.textContent = 'Supprimer';
        del.addEventListener('click', () => { state.tools.splice(i, 1); renderTools(); });
        header.appendChild(del);
        const grid = document.createElement('div');
        grid.className = 'grid grid-cols-1 sm:grid-cols-2 gap-3';
        const nameInput = document.createElement('input');
        nameInput.type = 'text';
        nameInput.value = tool.name;
        nameInput.placeholder = 'Nom (ex: CalendlyAPI)';
        nameInput.className = 'bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:border-primary transition-colors';
        nameInput.addEventListener('input', () => { state.tools[i].name = nameInput.value; });
        const trigInput = document.createElement('input');
        trigInput.type = 'text';
        trigInput.value = tool.trigger;
        trigInput.placeholder = 'Déclencheur (ex: Quand le prospect veut un RDV)';
        trigInput.className = 'bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:border-primary transition-colors';
        trigInput.addEventListener('input', () => { state.tools[i].trigger = trigInput.value; });
        grid.appendChild(nameInput);
        grid.appendChild(trigInput);
        row.appendChild(header);
        row.appendChild(grid);
        list.appendChild(row);
      });
    }

    function setTransferUI(enabled) {
      state.transferEnabled = enabled;
      const toggle = document.getElementById('transfer-toggle');
      const knob = document.getElementById('transfer-knob');
      const fields = document.getElementById('transfer-fields');
      toggle.setAttribute('aria-checked', enabled ? 'true' : 'false');
      if (enabled) {
        toggle.classList.remove('bg-slate-200');
        toggle.classList.add('bg-primary');
        knob.classList.add('translate-x-5');
      } else {
        toggle.classList.add('bg-slate-200');
        toggle.classList.remove('bg-primary');
        knob.classList.remove('translate-x-5');
      }
      fields.classList.toggle('hidden', !enabled);
    }

    function applyPersona(key) {
      const p = PERSONAS[key];
      if (!p) return;
      document.getElementById('byv-name').value = p.name;
      document.getElementById('byv-role').value = p.role;
      document.getElementById('byv-company').value = p.company;
      document.getElementById('byv-industry').value = p.industry;
      document.getElementById('byv-signature').value = p.signature;
      state.selectedTone = p.tones[0] || '';
      state.selectedTraits = [...p.traits];
      state.selectedHumor = p.humor;
      state.selectedStyle = p.style;
      state.selectedFeatures = [...p.features];
      state.selectedDataFields = [...p.dataFields];
      state.objectives = [...p.objectives];
      activateChips('tone-chips', p.tones[0] || '');
      activateChips('traits-chips', p.traits);
      activateChips('humor-chips', p.humor);
      activateChips('style-chips', p.style);
      activateChips('features-chips', p.features);
      activateChips('data-chips', p.dataFields);
      renderObjectives();
      setTransferUI(p.transfer);
      document.getElementById('byv-transfer-condition').value = p.transferCondition;
      document.getElementById('byv-transfer-message').value = p.transferMessage;
      document.getElementById('byv-must-do').value = p.mustDo;
      document.getElementById('byv-must-not').value = p.mustNot;
      document.getElementById('byv-knowledge-products').value = p.products;
      document.getElementById('byv-knowledge-faq').value = p.faq;
      document.querySelectorAll('.persona-card').forEach(card => {
        const isSelected = card.dataset.persona === key;
        card.classList.toggle('border-primary', isSelected);
        card.classList.toggle('border-slate-200', !isSelected);
      });
      document.getElementById('form-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function generatePrompt() {
      const name = document.getElementById('byv-name').value.trim() || 'Assistant';
      const role = document.getElementById('byv-role').value.trim() || 'Agent vocal';
      const company = document.getElementById('byv-company').value.trim();
      const industry = document.getElementById('byv-industry').value.trim();
      const signature = document.getElementById('byv-signature').value.trim();
      const toneLabel = TONES.find(t => t.id === state.selectedTone) ? TONES.find(t => t.id === state.selectedTone).label : '';
      const traitLabels = state.selectedTraits.map(t => { const f = TRAITS.find(tr => tr.id === t); return f ? f.label : t; });
      const humorLabel = HUMORS.find(h => h.id === state.selectedHumor) ? HUMORS.find(h => h.id === state.selectedHumor).label : '';
      const styleLabel = STYLES.find(s => s.id === state.selectedStyle) ? STYLES.find(s => s.id === state.selectedStyle).label : '';
      const featureLabels = state.selectedFeatures.map(f => { const fe = FEATURES.find(x => x.id === f); return fe ? fe.label : f; });
      const dataLabels = state.selectedDataFields.map(d => { const df = DATA_FIELDS.find(x => x.id === d); return df ? df.label : d; });
      const objectives = state.objectives.filter(o => o.trim());
      const mustDo = document.getElementById('byv-must-do').value.trim().split('\n').filter(l => l.trim());
      const mustNot = document.getElementById('byv-must-not').value.trim().split('\n').filter(l => l.trim());
      const products = document.getElementById('byv-knowledge-products').value.trim();
      const faq = document.getElementById('byv-knowledge-faq').value.trim();
      const transferCondition = document.getElementById('byv-transfer-condition').value.trim();
      const transferMessage = document.getElementById('byv-transfer-message').value.trim();
      const tools = state.tools.filter(t => t.name.trim());

      let prompt = '# PROMPT SYSTÈME — ' + name.toUpperCase() + '\n';
      prompt += '# Généré par Mindeon.ai BuildYourVoice\n\n';
      prompt += '---\n\n';
      prompt += '## IDENTITÉ\n';
      prompt += 'Tu t\'appelles ' + name + '. Tu es ' + role;
      if (company) prompt += ' pour ' + company;
      if (industry) prompt += ', dans le secteur ' + industry;
      prompt += '.\n';
      if (signature) prompt += '\nEn fin d\'appel, tu utilises systématiquement ta phrase signature :\n"' + signature + '"\n';
      prompt += '\n---\n\n';
      prompt += '## PERSONNALITÉ & STYLE DE COMMUNICATION\n';
      if (toneLabel) prompt += 'Ton principal : ' + toneLabel + '\n';
      if (traitLabels.length) prompt += 'Traits de caractère : ' + traitLabels.join(', ') + '\n';
      if (humorLabel) prompt += 'Humour : ' + humorLabel + '\n';
      if (styleLabel) prompt += 'Style de réponse : ' + styleLabel + '\n';
      prompt += '\n---\n';
      if (featureLabels.length) {
        prompt += '\n## FONCTIONNALITÉS\nTu es capable de :\n';
        featureLabels.forEach(f => { prompt += '- ' + f + '\n'; });
        prompt += '\n---\n';
      }
      if (objectives.length) {
        prompt += '\n## OBJECTIFS PRINCIPAUX\n';
        objectives.forEach((o, i) => { prompt += (i + 1) + '. ' + o + '\n'; });
        prompt += '\n---\n';
      }
      if (dataLabels.length) {
        prompt += '\n## DONNÉES À COLLECTER\nTu dois impérativement collecter les informations suivantes au cours de l\'appel :\n';
        dataLabels.forEach(d => { prompt += '- ' + d + '\n'; });
        prompt += '\n---\n';
      }
      if (state.transferEnabled && transferCondition) {
        prompt += '\n## TRANSFERT HUMAIN\n';
        prompt += 'Conditions de transfert : ' + transferCondition + '\n';
        if (transferMessage) prompt += 'Message de transition : "' + transferMessage + '"\n';
        prompt += '\n---\n';
      }
      if (mustDo.length) {
        prompt += '\n## RÈGLES — CE QUE TU DOIS TOUJOURS FAIRE\n';
        mustDo.forEach(r => { prompt += '- ' + r + '\n'; });
        prompt += '\n---\n';
      }
      if (mustNot.length) {
        prompt += '\n## RÈGLES — CE QUE TU NE DOIS JAMAIS FAIRE\n';
        mustNot.forEach(r => { prompt += '- ' + r + '\n'; });
        prompt += '\n---\n';
      }
      if (products || faq) {
        prompt += '\n## BASE DE CONNAISSANCE\n';
        if (products) prompt += '### Produits & Services\n' + products + '\n\n';
        if (faq) prompt += '### FAQ\n' + faq + '\n\n';
        prompt += '---\n';
      }
      if (tools.length) {
        prompt += '\n## OUTILS & INTÉGRATIONS\nTu as accès aux outils suivants :\n';
        tools.forEach(t => { prompt += '- ' + t.name + (t.trigger ? ' → ' + t.trigger : '') + '\n'; });
        prompt += '\n---\n';
      }
      prompt += '\n# FIN DU PROMPT — ' + name.toUpperCase();

      document.getElementById('output-prompt').textContent = prompt;
      const out = document.getElementById('output-section');
      out.classList.remove('hidden');
      out.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.addEventListener('DOMContentLoaded', function () {
      renderChips('tone-chips', TONES, 'tone');
      renderChips('traits-chips', TRAITS, 'traits');
      renderChips('humor-chips', HUMORS, 'humor');
      renderChips('style-chips', STYLES, 'style');
      renderChips('features-chips', FEATURES, 'features');
      renderChips('data-chips', DATA_FIELDS, 'data');
      renderObjectives();

      document.getElementById('transfer-toggle').addEventListener('click', function () {
        setTransferUI(!state.transferEnabled);
      });

      document.getElementById('add-objective-btn').addEventListener('click', function () {
        if (state.objectives.length < 5) { state.objectives.push(''); renderObjectives(); }
      });

      document.getElementById('tools-toggle-btn').addEventListener('click', function () {
        const section = document.getElementById('tools-section');
        const hidden = section.classList.toggle('hidden');
        this.textContent = hidden ? 'Afficher' : 'Masquer';
      });

      document.getElementById('add-tool-btn').addEventListener('click', function () {
        if (state.tools.length < 5) { state.tools.push({ name: '', trigger: '' }); renderTools(); }
      });

      document.querySelectorAll('.persona-card').forEach(function (card) {
        card.addEventListener('click', function () { applyPersona(card.dataset.persona); });
      });

      document.getElementById('generate-btn').addEventListener('click', generatePrompt);

      document.getElementById('copy-btn').addEventListener('click', function () {
        const text = document.getElementById('output-prompt').textContent;
        navigator.clipboard.writeText(text).then(function () {
          document.getElementById('copy-label').textContent = '✓ Copié !';
          document.getElementById('copy-btn').classList.add('bg-green-600');
          setTimeout(function () {
            document.getElementById('copy-label').textContent = 'Copier';
            document.getElementById('copy-btn').classList.remove('bg-green-600');
          }, 2000);
        });
      });
    });
  </script>

</BaseLayout>
