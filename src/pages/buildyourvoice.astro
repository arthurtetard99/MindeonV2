        features: ['sell', 'qualify', 'objections', 'upsell'],
        objectives: ["Qualifier le potentiel du prospect", "Présenter les offres clés", "Conclure ou planifier une démo", "Gérer les objections de prix ou timing"],
        dataFields: ['name', 'company', 'needs', 'budget', 'timeline'],
        transfer: true, transferCondition: 'Prospect très qualifié demandant à parler à un commercial senior', transferMessage: "Je vous mets en relation avec l'un de nos experts disponible.",
