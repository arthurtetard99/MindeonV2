---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import LogoBanner from '../components/home/LogoBanner.astro';
import Solutions from '../components/home/Solutions.astro';
import SocialProof from '../components/home/SocialProof.astro';
import FeaturedProject from '../components/home/FeaturedProject.astro';
import Testimonials from '../components/home/Testimonials.astro';
import Methodology from '../components/home/Methodology.astro';
import CTASection from '../components/home/CTASection.astro';
import FAQ from '../components/home/FAQ.astro';
---

<BaseLayout
  title="Agence agents IA et automatisation pour PME"
  description="Agence IA spécialisée en voice bots, chatbots RAG et automatisation CRM avec n8n. 3 ingénieurs, 15+ projets livrés pour PME et startups. Consultation gratuite 30 min."
  pathname="/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Mindeon.ai",
    "url": "https://mindeon.ai",
    "telephone": "+33667699490",
    "email": "contact@mindeon.ai",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Paris",
      "addressCountry": "FR"
    },
    "description": "Agence IA pour PME : voice bots, chatbots et automatisation CRM sur-mesure."
  })} />
  <Hero />
  <LogoBanner />
  <Solutions />
  <SocialProof />
  <FeaturedProject />
  <Testimonials />
  <Methodology />
  <FAQ />
  <CTASection />
</BaseLayout>
