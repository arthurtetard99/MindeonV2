---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';
import team from '../data/team.json';
---

<BaseLayout
  title="Notre équipe de 3 ingénieurs IA"
  description="Rencontrez David, Cambyse et Arthur — 3 ingénieurs spécialisés en IA, automatisation et développement. Anciens de Renault, APHP, Soprasteria."
  pathname="/equipe/"
>
  <!-- Header -->
  <section class="bg-slate-50 border-b border-slate-200 pt-16 pb-20 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <Badge>Notre équipe</Badge>
      <h1 class="mt-4 text-5xl font-extrabold text-slate-900 leading-tight tracking-tight mb-4">
        3 ingénieurs, un seul objectif
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed">
        Anciens de Renault, APHP et Soprasteria, nous avons quitté le monde du conseil pour construire des systèmes IA qui livrent de vraies résultats.
      </p>
    </div>
  </section>

  <!-- Team grid -->
  <section class="py-24" aria-labelledby="team-heading">
    <div class="max-w-5xl mx-auto px-6">
      <h2 id="team-heading" class="sr-only">Les membres de l'équipe</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {team.map(member => (
          <article class="flex flex-col bg-white border border-slate-200 rounded-2xl p-8 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <!-- Photo -->
            <div class="w-28 h-28 rounded-2xl overflow-hidden mx-auto mb-5 bg-primary-light">
              {member.photo
                ? <img src={member.photo} alt={member.name} width="112" height="112" class={`w-full h-full object-cover object-top${member.id === 'arthur' ? ' scale-110' : ''}`} loading="lazy" />
                : <span class="w-full h-full flex items-center justify-center text-primary font-extrabold text-2xl" aria-hidden="true">{member.initials}</span>
              }
            </div>
            <h2 class="font-bold text-slate-900 text-lg">{member.name}</h2>
            <p class="text-primary text-sm font-semibold mt-1 mb-4">{member.role}</p>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-1">{member.bio}</p>
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-primary transition-colors mx-auto"
              aria-label={`LinkedIn de ${member.name} (nouvelle fenêtre)`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-slate-50 border-y border-slate-100 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-slate-900 text-center mb-12">Ce qui nous distingue</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { title: 'Ingénieurs, pas consultants', text: "On code et on déploie nous-mêmes. Pas de sous-traitance, pas de middle-man." },
          { title: 'ROI avant tout', text: "Chaque projet est évalué sur ses résultats mesurables. Pas de fonctionnalités gadgets." },
          { title: 'Transparence totale', text: "Code documenté, process partagé, démos hebdomadaires. Vous êtes toujours dans la boucle." },
        ].map(v => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-xl bg-primary-light text-primary flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-2">{v.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">On discute de votre projet ?</h2>
      <p class="text-slate-600 mb-8">30 minutes, gratuit, sans engagement.</p>
      <a href="/contact/" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 shadow-[0_4px_14px_rgba(37,99,235,0.3)] hover:scale-[1.02] active:scale-95">
        Prendre rendez-vous →
      </a>
    </div>
  </section>
</BaseLayout>
