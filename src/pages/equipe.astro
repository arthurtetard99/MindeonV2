---
import BaseLayout from '../layouts/BaseLayout.astro';
import team from '../data/team.json';

const values = [
  {
    title: 'Code ownership',
    text: 'Vous êtes propriétaire à 100% du code et des modèles déployés. Pas de dépendance, pas de black box.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    title: 'ROI avant tout',
    text: 'Chaque agent est conçu pour réduire vos coûts ou augmenter votre CA. Pas de fonctionnalités gadgets.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  },
  {
    title: 'Transparence totale',
    text: 'Code documenté, process partagé, démos hebdomadaires. Vous êtes toujours dans la boucle.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 9 5 12V9l-5 12"/><path d="M9 9h7"/></svg>`,
  },
];
---

<BaseLayout
  title="Notre équipe de 3 ingénieurs IA"
  description="Rencontrez David, Cambyse et Arthur — 3 ingénieurs spécialisés en IA, automatisation et développement. Anciens de Renault, APHP, Soprasteria."
  pathname="/equipe/"
>

  <!-- Hero -->
  <header class="pt-40 pb-20 px-6 bg-white text-center">
    <div class="max-w-4xl mx-auto">
      <span class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-primary text-[10px] uppercase tracking-widest font-bold mb-6">
        L'Expertise Mindeon
      </span>
      <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight leading-tight mb-8">
        3 ingénieurs, une mission :<br>
        <span class="text-primary">automatiser l'avenir.</span>
      </h1>
      <p class="text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed">
        Anciens de Renault, APHP et Soprasteria, nous avons quitté le monde du conseil pour construire des systèmes IA qui livrent de vraies résultats.
      </p>
    </div>
  </header>

  <!-- Team grid -->
  <section class="py-24 px-6 bg-slate-50" aria-labelledby="team-heading">
    <div class="max-w-5xl mx-auto">
      <h2 id="team-heading" class="sr-only">Les membres de l'équipe</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {team.map(member => (
          <div class="group">
            <!-- Photo -->
            <div class="relative mb-8 rounded-2xl overflow-hidden aspect-[4/5] bg-slate-200 max-h-72 md:max-h-80">
              {member.photo
                ? <img
                    src={member.photo}
                    alt={`Portrait de ${member.name}`}
                    class={`w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105${member.id === 'arthur' ? ' scale-110' : ''}`}
                    loading="lazy"
                  />
                : <span class="w-full h-full flex items-center justify-center text-primary font-extrabold text-3xl bg-blue-50" aria-hidden="true">{member.initials}</span>
              }
              <!-- Hover overlay with LinkedIn -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <a
                  href={member.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-white/90 backdrop-blur-sm px-4 py-2 rounded-full flex items-center gap-2 text-primary font-semibold text-sm hover:bg-white transition-colors"
                  aria-label={`LinkedIn de ${member.name} (nouvelle fenêtre)`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

            <!-- Info -->
            <h3 class="text-2xl font-extrabold text-slate-900 mb-1">{member.name}</h3>
            <p class="text-primary text-xs uppercase tracking-wider font-bold mb-4">{member.role}</p>
            <p class="text-slate-500 leading-relaxed text-sm">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-24 px-6 bg-blue-50">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-16 items-start">
        <div class="w-full md:w-1/3 md:pt-2">
          <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4 leading-tight">
            L'excellence comme standard.
          </h2>
          <p class="text-slate-500 leading-relaxed">
            Plus que du code, nous bâtissons des actifs numériques pérennes pour votre entreprise.
          </p>
        </div>
        <div class="w-full md:w-2/3 grid grid-cols-1 sm:grid-cols-3 gap-6">
          {values.map(v => (
            <div class="bg-white p-8 rounded-2xl">
              <div class="text-primary mb-4">
                <Fragment set:html={v.icon} />
              </div>
              <h4 class="font-extrabold text-slate-900 text-base mb-2">{v.title}</h4>
              <p class="text-slate-500 text-sm leading-relaxed">{v.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto bg-slate-900 rounded-2xl p-12 text-center relative overflow-hidden">
      <!-- Decorative blobs -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary opacity-20 blur-[80px]" aria-hidden="true"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-violet-600 opacity-10 blur-[80px]" aria-hidden="true"></div>

      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6 tracking-tight">
          Prêt à passer à l'échelle supérieure ?
        </h2>
        <p class="text-slate-400 max-w-xl mx-auto mb-10 text-lg leading-relaxed">
          Rejoignez les entreprises qui automatisent leur croissance grâce à nos agents IA sur-mesure.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/"
            class="bg-primary hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-bold transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.4)] hover:scale-[1.02] active:scale-95"
          >
            Lancer mon projet
          </a>
          <a
            href="/nos-projets/"
            class="bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold backdrop-blur-sm transition-all duration-200"
          >
            Consulter nos projets
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
