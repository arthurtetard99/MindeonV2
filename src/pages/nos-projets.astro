---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projets = await getCollection('projets');
const sorted = projets.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Banner config per tag
function getBanner(tags: string[]): { gradient: string; label: string; pattern: string; accent: string } {
  const all = tags.map(t => t.toLowerCase()).join(' ');
  if (all.includes('voice') || all.includes('vapi') || all.includes('retell'))
    return { gradient: 'from-blue-600 to-blue-800', label: 'Voice Bot', pattern: 'dots', accent: 'text-primary' };
  if (all.includes('whatsapp') || all.includes('chatbot') || all.includes('conversationnel'))
    return { gradient: 'from-violet-600 to-purple-800', label: 'Agent IA', pattern: 'lines', accent: 'text-violet-600' };
  if (all.includes('webapp') || all.includes('full-stack'))
    return { gradient: 'from-indigo-600 to-indigo-800', label: 'Web App', pattern: 'dots', accent: 'text-indigo-600' };
  if (all.includes('devis') || all.includes('pdf') || all.includes('qualification') || all.includes('pipeline'))
    return { gradient: 'from-violet-600 to-purple-900', label: 'Agent IA', pattern: 'lines', accent: 'text-violet-600' };
  if (all.includes('crm') || all.includes('axonaut') || all.includes('fabrication'))
    return { gradient: 'from-blue-600 to-blue-800', label: 'Automatisation CRM', pattern: 'dots', accent: 'text-primary' };
  return { gradient: 'from-emerald-600 to-teal-800', label: 'Workflow IA', pattern: 'dots', accent: 'text-emerald-600' };
}
---

<BaseLayout
  title="Nos projets d'agents IA et d'automatisation"
  description="Découvrez nos réalisations : voice bots, agents conversationnels, automatisations CRM. Plus de 15 projets livrés pour des PME et startups."
  pathname="/nos-projets/"
>
  <main class="pt-28 pb-24 px-6 md:px-10 lg:px-16 max-w-7xl mx-auto">

    <!-- Hero -->
    <header class="mb-20 max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-primary text-xs font-bold tracking-widest uppercase mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
        Portfolio
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight mb-6 leading-[1.1]">
        15+ projets livrés
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed">
        Nous concevons des infrastructures d'IA sur-mesure qui transforment l'efficacité opérationnelle. Découvrez comment l'automatisation intelligente redéfinit les standards industriels.
      </p>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      {sorted.map((projet) => {
        const { gradient, label, accent } = getBanner(projet.data.tags ?? []);
        const results = projet.data.results ?? [];
        return (
          <a
            href={`/${projet.slug}/`}
            class="group bg-white rounded-3xl overflow-hidden flex flex-col shadow-[0_20px_40px_rgba(13,28,47,0.04)] hover:shadow-[0_20px_48px_rgba(13,28,47,0.10)] transition-all duration-500"
            aria-label={projet.data.title}
          >
            <!-- Colored banner -->
            <div class={`h-64 bg-gradient-to-br ${gradient} relative overflow-hidden flex items-center justify-center`}>
              <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
              <div class="absolute top-6 left-6 px-4 py-1.5 bg-white/20 backdrop-blur-md rounded-full text-white text-xs font-bold tracking-wider uppercase">
                {label}
              </div>
            </div>

            <!-- Card body -->
            <div class="p-8 md:p-10 flex-1 flex flex-col">
              <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-4 leading-tight tracking-tight">
                {projet.data.title}
              </h2>
              <p class="text-slate-500 text-lg mb-8 leading-relaxed">
                {projet.data.description}
              </p>

              <!-- Results bullets -->
              {results.length > 0 && (
                <ul class="space-y-3 mb-10">
                  {results.slice(0, 2).map((r: string) => (
                    <li class="flex items-start gap-3">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`${accent} shrink-0 mt-0.5`} aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                      <span class="text-slate-700 font-medium">{r}</span>
                    </li>
                  ))}
                </ul>
              )}

              <!-- Link -->
              <div class="mt-auto">
                <span class={`inline-flex items-center gap-2 ${accent} font-bold group-hover:gap-4 transition-all duration-300`}>
                  Voir le projet
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </div>

          </a>
        );
      })}
    </div>

    <!-- CTA -->
    <section class="mt-28 p-12 md:p-20 rounded-[3rem] bg-slate-50 text-center relative overflow-hidden" aria-labelledby="cta-projets-heading">
      <div class="absolute top-0 right-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>
      <div class="relative z-10 max-w-2xl mx-auto">
        <h2 id="cta-projets-heading" class="text-4xl font-extrabold text-slate-900 mb-6 tracking-tight">
          Votre projet est le prochain
        </h2>
        <p class="text-slate-500 text-lg mb-10">
          Collaborons pour concevoir la solution d'intelligence artificielle qui fera passer votre entreprise à l'échelle supérieure.
        </p>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-2xl transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.35)] hover:scale-[1.02] active:scale-95 text-lg"
        >
          Discuter de mon besoin
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
