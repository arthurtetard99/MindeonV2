---
import SectionHeading from '../ui/SectionHeading.astro';
import TestimonialCard from '../ui/TestimonialCard.astro';
import testimonials from '../../data/testimonials.json';
---

<section class="bg-[#f0f4ff] py-24" aria-labelledby="testimonials-heading">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeading
      badge="Wall of trust"
      title="Ce que disent nos clients"
      subtitle="Découvrez comment Mindeon.ai transforme les opérations de nos clients grâce à des agents IA sur-mesure."
      center
    />

    <div class="reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.slice(0, 3).map((t) => (
        <TestimonialCard
          name={t.name}
          company={t.company}
          role={t.role}
          rating={t.rating}
          text={t.text}
          initials={t.initials}
        />
      ))}
    </div>

    <!-- Malt badge -->
    <div class="mt-12 flex justify-center">
      <a
        href="https://www.malt.fr"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white rounded-full px-5 py-3 shadow-sm hover:shadow-md transition-shadow duration-200"
        aria-label="Voir nos avis sur Malt (nouvelle fenêtre)"
      >
        <!-- Malt M logo -->
        <div class="w-6 h-6 rounded-md bg-[#FC4F37] flex items-center justify-center shrink-0" aria-hidden="true">
          <span class="text-white font-extrabold text-xs leading-none">M</span>
        </div>
        <span class="text-slate-700 text-sm font-medium">5/5 sur Malt — 5 avis vérifiés</span>
      </a>
    </div>
  </div>
</section>
