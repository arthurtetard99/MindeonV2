---
---

<section class="py-24 px-6" aria-labelledby="cta-heading">
  <div class="max-w-7xl mx-auto">
    <div class="reveal relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-700 via-blue-800 to-blue-900 text-white text-center px-8 py-20 md:px-16 md:py-28">

      <!-- Decorative dots -->
      <div class="absolute inset-0 opacity-[0.07] dot-pattern-lg" aria-hidden="true"></div>

      <!-- Decorative blobs -->
      <div class="absolute -top-16 -left-16 w-64 h-64 bg-white/5 rounded-full blur-3xl" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -right-16 w-64 h-64 bg-white/5 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-xs font-bold tracking-widest uppercase mb-8">
          Consultation gratuite
        </div>

        <h2 id="cta-heading" class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6">
          Prêt à automatiser<br />votre business ?
        </h2>

        <p class="text-xl text-blue-100 max-w-2xl mx-auto mb-10 leading-relaxed">
          Réservez 30 min avec notre équipe — c'est gratuit, concret, et sans PowerPoint.
        </p>

        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 bg-white text-primary font-extrabold text-base px-10 py-5 rounded-2xl hover:shadow-2xl hover:scale-[1.03] active:scale-95 transition-all duration-200"
          >
            Réserver une consultation gratuite →
          </a>
          <a
            href="/nos-projets/"
            class="inline-flex items-center gap-2 border border-white/30 text-white font-bold text-base px-10 py-5 rounded-2xl hover:bg-white/10 transition-all duration-200"
          >
            Voir nos réalisations
          </a>
        </div>

        <!-- Trust line -->
        <p class="mt-8 text-blue-200 text-sm">
          ★ 5/5 sur Malt · 15+ projets livrés · Réponse sous 24h
        </p>
      </div>
    </div>
  </div>
</section>
