---
const metrics = [
  { value: '15', suffix: '+', label: 'Projets déployés' },
  { value: '5',  suffix: '/5', label: 'Note sur Malt' },
  { value: '-60', suffix: '%', label: 'Coûts opérationnels' },
  { value: '24', suffix: '/7', label: 'Disponibilité agents' },
];
---

<section class="bg-slate-50 py-24" aria-labelledby="proof-heading">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Metrics -->
      <div class="reveal grid grid-cols-2 gap-4">
        {metrics.map((m) => (
          <div class="bg-white border border-slate-200 rounded-xl p-6 md:p-8">
            <div class="flex items-baseline gap-0.5">
              <span
                class="text-4xl md:text-5xl font-extrabold text-primary counter"
                data-target={m.value}
              >
                {m.value}
              </span>
              <span class="text-2xl font-extrabold text-primary">{m.suffix}</span>
            </div>
            <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mt-2">{m.label}</p>
          </div>
        ))}
      </div>

      <!-- Quote -->
      <div class="reveal">
        <h2 id="proof-heading" class="text-3xl md:text-4xl font-bold text-slate-900 leading-tight mb-6">
          Automatisation CRM, agents IA et voice bots — un ROI mesurable pour les PME.
        </h2>
        <blockquote class="border-l-4 border-primary pl-6">
          <p class="text-lg text-slate-600 leading-relaxed italic">
            "L'IA n'est pas un gadget, c'est un moteur de productivité. Nous ne construisons pas seulement des outils, nous bâtissons l'infrastructure qui permet à nos clients de se concentrer sur l'essentiel."
          </p>
        </blockquote>
        <div class="flex items-center gap-4 mt-8">
          <div class="w-12 h-12 rounded-full bg-primary-light text-primary font-bold flex items-center justify-center text-sm shrink-0" aria-hidden="true">
            MT
          </div>
          <div>
            <p class="font-bold text-slate-900">Équipe Mindeon.ai</p>
            <p class="text-sm text-slate-500">David · Cambyse · Arthur</p>
          </div>
        </div>

        <!-- CTA -->
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 mt-8 bg-primary hover:bg-primary-dark text-white font-bold px-6 py-3 rounded-xl transition-all duration-200 shadow-[0_2px_8px_rgba(37,99,235,0.25)] hover:scale-[1.02] active:scale-95"
        >
          Réserver une consultation gratuite
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  // Animate counters when visible
  const counters = document.querySelectorAll<HTMLElement>('.counter');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target ?? '0', 10);
      const isNegative = target < 0;
      const abs = Math.abs(target);
      let current = 0;
      const step = Math.max(1, Math.floor(abs / 40));
      const timer = setInterval(() => {
        current = Math.min(current + step, abs);
        el.textContent = (isNegative ? '-' : '') + current.toString();
        if (current >= abs) clearInterval(timer);
      }, 30);
      observer.unobserve(el);
    });
  }, { threshold: 0.5 });

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    counters.forEach(c => observer.observe(c));
  }
</script>
