---
import { Image } from 'astro:assets';
import tools from '../../data/tools.json';

type ImageModule = { default: ImageMetadata };
const toolImages = import.meta.glob<ImageModule>('../../assets/images/tools/*', { eager: true });

function getToolImage(logoPath: string): ImageMetadata | undefined {
  const filename = logoPath.split('/').pop() ?? '';
  return toolImages[`../../assets/images/tools/${filename}`]?.default;
}

const doubled = [...tools, ...tools];
const withLabel = new Set(['Retell AI', 'Claude', 'n8n', 'Mistral AI', 'Power Automate', 'Microsoft Azure']);
---

<section class="bg-slate-50 border-y border-slate-100 py-14" aria-label="Nos outils phares">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-center text-xs font-bold tracking-widest uppercase text-slate-400 mb-10">
      Nos outils phares
    </p>
  </div>

  <div class="relative overflow-hidden">
    <!-- Gradient fades -->
    <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-slate-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-slate-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>

    <div class="flex items-center gap-[72px] animate-marquee w-max" aria-hidden="true">
      {doubled.map((tool) => {
        const img = getToolImage(tool.logo);
        return (
          <div class="flex flex-col items-center shrink-0 opacity-80 hover:opacity-100 transition-opacity duration-300 cursor-default select-none">
            {img && (
              <Image
                src={img}
                alt={tool.name}
                height={64}
                format="webp"
                class="h-16 w-auto"
                loading="lazy"
              />
            )}
            {withLabel.has(tool.name) && (
              <span class="mt-2 text-xs font-semibold text-slate-400 text-center">{tool.name}</span>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
