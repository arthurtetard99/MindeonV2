---
const year = new Date().getFullYear();

const services = [
  { label: 'Voice Agents', href: '/nos-projets/' },
  { label: 'Chatbots RAG', href: '/nos-projets/' },
  { label: 'Audit IA', href: '/contact/' },
  { label: 'Workflows n8n', href: '/nos-projets/' },
];

const agence = [
  { label: 'À propos', href: '/equipe/' },
  { label: 'Projets', href: '/nos-projets/' },
  { label: 'Articles', href: '/articles/' },
  { label: 'Ressources', href: '/ressources/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Contact', href: '/contact/' },
];

const legales = [
  { label: 'Confidentialité', href: '/politique-de-confidentialite/' },
  { label: 'Cookies', href: '/politique-de-cookies/' },
  { label: 'CGV', href: '/cgv/' },
  { label: 'CGU', href: '/cgu/' },
  { label: 'Mentions légales', href: '/mentions-legales/' },
];
---

<footer class="bg-slate-900 text-slate-300">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-5" aria-label="Mindeon.ai">
          <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center shrink-0">
            <span class="text-white font-extrabold text-sm">M</span>
          </div>
          <span class="font-extrabold text-lg text-white tracking-tight">Mindeon.ai</span>
        </a>
        <p class="text-sm leading-relaxed text-slate-400 max-w-xs">
          Agence IA et automatisation pour PME et startups. Nous transformons vos processus manuels en systèmes autonomes qui livrent des résultats mesurables.
        </p>
        <div class="flex items-center gap-2 mt-6">
          <a
            href="https://www.linkedin.com/company/mindeon"
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-lg bg-slate-800 hover:bg-primary flex items-center justify-center transition-colors duration-200"
            aria-label="Mindeon.ai sur LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
        <div class="mt-4 space-y-2">
          <a href="tel:+33667699490" class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors duration-200 py-2 min-h-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 5.82 5.82l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>
            +33 6 67 69 94 90
          </a>
          <a href="mailto:contact@mindeon.ai" class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors duration-200 py-2 min-h-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            contact@mindeon.ai
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-bold text-xs uppercase tracking-widest text-primary mb-6">Services</h3>
        <ul class="space-y-3">
          {services.map(item => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200 block py-1.5 min-h-[44px] flex items-center">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Agence -->
      <div>
        <h3 class="font-bold text-xs uppercase tracking-widest text-primary mb-6">Agence</h3>
        <ul class="space-y-3">
          {agence.map(item => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200 block py-1.5 min-h-[44px] flex items-center">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-bold text-xs uppercase tracking-widest text-primary mb-6">Newsletter</h3>
        <p class="text-sm text-slate-400 mb-4">Nos dernières veilles IA directement dans votre boîte.</p>
        <form class="flex flex-col gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="votre@email.com"
            aria-label="Adresse email pour la newsletter"
            class="bg-slate-800 text-white text-sm px-4 py-2.5 rounded-lg border border-slate-700 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 placeholder:text-slate-500 transition-colors"
          />
          <button
            type="submit"
            class="bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-3 rounded-lg transition-colors duration-200 min-h-[48px]"
          >
            S'abonner →
          </button>
        </form>
        <p class="text-xs text-slate-500 mt-3">Zéro spam. Désabonnement en 1 clic.</p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-slate-500">
        © {year} Mindeon.ai. Tous droits réservés.
      </p>
      <div class="flex flex-wrap gap-6">
        {legales.map(item => (
          <a href={item.href} class="text-xs text-slate-500 hover:text-slate-300 transition-colors duration-200 py-2 min-h-[44px] flex items-center">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
