---
interface Props {
  name: string;
  company: string;
  role: string;
  rating: number;
  text: string;
  initials: string;
}

const { name, company, role, rating, text, initials } = Astro.props;
---

<article class="bg-white rounded-2xl p-8 flex flex-col gap-5 shadow-sm">
  <!-- Stars -->
  <div class="flex gap-1" aria-label={`Note : ${rating} étoiles sur 5`}>
    {Array.from({ length: rating }).map(() => (
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#F59E0B" stroke="#F59E0B" stroke-width="1" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>

  <!-- Text -->
  <p class="text-slate-700 text-[0.95rem] leading-relaxed flex-1">"{text}"</p>

  <!-- Author -->
  <div class="flex items-center gap-3 mt-2">
    <div class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center shrink-0" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </div>
    <div>
      <p class="font-bold text-slate-900 text-sm">{name}</p>
      <p class="text-xs text-slate-500">{role} at {company}</p>
    </div>
  </div>
</article>
