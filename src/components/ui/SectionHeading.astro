---
import Badge from './Badge.astro';

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  center?: boolean;
  class?: string;
}

const { badge, title, subtitle, center = false, class: className = '' } = Astro.props;
---

<div class={`mb-16 ${center ? 'text-center' : ''} ${className}`}>
  {badge && (
    <Badge class="mb-4">{badge}</Badge>
  )}
  <h2 class="text-4xl md:text-[2.75rem] font-extrabold text-slate-900 leading-tight tracking-tight mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-lg text-slate-600 leading-relaxed ${center ? 'max-w-2xl mx-auto' : 'max-w-2xl'}`}>
      {subtitle}
    </p>
  )}
</div>
