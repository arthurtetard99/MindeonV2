---
import BaseLayout from './BaseLayout.astro';
import Illustration from '../components/ui/Illustration.astro';
import { formatDate } from '../utils/helpers';

interface Props {
  title: string;
  description: string;
  pathname: string;
  client?: string;
  date?: Date;
  tags?: string[];
  results?: string[];
}

const { title, description, pathname, client, date, tags = [], results = [] } = Astro.props;

function getIllustrationTopic(tags: string[]): string {
  const all = tags.map(t => t.toLowerCase()).join(' ');
  if (all.includes('voice') || all.includes('vapi') || all.includes('retell') || all.includes('vocal')) return 'voice';
  if (all.includes('whatsapp') || all.includes('chatbot') || all.includes('conversationnel') || all.includes('rag')) return 'chatbot';
  if (all.includes('webapp') || all.includes('full-stack') || all.includes('gestion commandes')) return 'webapp';
  if (all.includes('devis') || all.includes('pdf') || all.includes('pipeline b2b') || all.includes('qualification')) return 'devis';
  if (all.includes('crm') || all.includes('axonaut') || all.includes('fabrication') || all.includes('trello')) return 'crm';
  return 'workflow';
}

// Try to extract a short stat prefix from a result sentence
function extractStat(result: string): { stat: string; label: string } {
  const match = result.match(/^([+\-]?\d[\d\s%€hkKmM\/+\-.]*(?:\/\d+)?)/);
  if (match) {
    return { stat: match[1].trim(), label: result.slice(match[1].length).replace(/^[\s–—\-:]+/, '').trim() };
  }
  // No leading number — show first 4 words as stat, rest as label
  const words = result.split(' ');
  return { stat: words.slice(0, 3).join(' '), label: words.slice(3).join(' ') };
}

const illustrationTopic = getIllustrationTopic(tags);
const category = tags[0] ?? 'Cas client';
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  schemaType="article"
  datePublished={date?.toISOString()}
>
  <main class="pt-32">

    <!-- Hero -->
    <section class="max-w-7xl mx-auto px-6 mb-20">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">

        <!-- Left -->
        <div class="lg:w-7/12">
          <a
            href="/nos-projets/"
            class="inline-flex items-center gap-2 text-slate-500 hover:text-primary text-sm font-medium mb-8 transition-colors group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Tous les projets
          </a>

          <span class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-primary text-xs font-bold tracking-wider uppercase mb-6">
            Cas client
          </span>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05] mb-8 text-slate-900">
            {title}
          </h1>

          <!-- Meta grid -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 py-8 border-t border-slate-100">
            {client && (
              <div>
                <p class="text-[10px] font-bold text-slate-400 tracking-widest uppercase mb-1">Client</p>
                <p class="font-semibold text-slate-800 text-sm">{client}</p>
              </div>
            )}
            {date && (
              <div>
                <p class="text-[10px] font-bold text-slate-400 tracking-widest uppercase mb-1">Date</p>
                <time class="font-semibold text-slate-800 text-sm" datetime={date.toISOString()}>{formatDate(date)}</time>
              </div>
            )}
            {tags.length > 0 && (
              <div>
                <p class="text-[10px] font-bold text-slate-400 tracking-widest uppercase mb-1">Technologies</p>
                <p class="font-semibold text-slate-800 text-sm">{tags.slice(0, 3).join(', ')}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Right: illustration -->
        <div class="lg:w-5/12 w-full">
          <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(13,28,47,0.12)]">
            <Illustration topic={illustrationTopic} class="w-full h-full" />
          </div>
        </div>

      </div>
    </section>

    <!-- KPI strip -->
    {results.length > 0 && (
      <section class="bg-blue-50 py-12 mb-24" aria-label="Résultats obtenus">
        <div class="max-w-7xl mx-auto px-6">
          <div class={`grid grid-cols-1 gap-6 ${results.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
            {results.map((result) => {
              const { stat, label } = extractStat(result);
              return (
                <div class="bg-white p-10 rounded-2xl flex flex-col items-center text-center shadow-sm">
                  <span class="text-4xl md:text-5xl font-black text-primary mb-3 leading-none">{stat}</span>
                  <p class="text-sm font-medium text-slate-500 leading-relaxed">{label}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Article content -->
    <div class="max-w-4xl mx-auto px-6 pb-24">
      <article class="project-content">
        <slot />
      </article>
    </div>

    <!-- CTA -->
    <section class="max-w-7xl mx-auto px-6 pb-24">
      <div class="bg-slate-50 rounded-2xl p-12 md:p-20 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-6">
          Prêt à automatiser vos workflows ?
        </h2>
        <p class="text-slate-500 mb-10 max-w-2xl mx-auto text-lg leading-relaxed">
          Découvrez comment nos solutions IA sur-mesure peuvent transformer votre efficacité opérationnelle et booster votre croissance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/"
            class="px-8 py-4 bg-primary hover:bg-blue-700 text-white rounded-xl font-bold transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.3)] hover:scale-[1.02] active:scale-95"
          >
            Parler à un expert
          </a>
          <a
            href="/nos-projets/"
            class="px-8 py-4 bg-white hover:bg-slate-100 text-slate-800 rounded-xl font-bold border border-slate-200 transition-all duration-200"
          >
            Voir d'autres projets
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .project-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .project-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .project-content :global(p) {
    color: #475569;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  .project-content :global(ul), .project-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #475569;
  }
  .project-content :global(li) {
    margin-bottom: 0.6rem;
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .project-content :global(ul > li) { list-style-type: disc; }
  .project-content :global(ol > li) { list-style-type: decimal; }
  .project-content :global(strong) { color: #0f172a; font-weight: 700; }
  .project-content :global(a) {
    color: #2563EB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .project-content :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .project-content :global(code:not(pre code)) {
    background: #f1f5f9;
    color: #2563EB;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .project-content :global(blockquote) {
    border-left: 3px solid #2563EB;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: #eff6ff;
    border-radius: 0 0.75rem 0.75rem 0;
    color: #334155;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .project-content :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }
  .project-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .project-content :global(th) {
    background: #f8fafc;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 700;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  .project-content :global(td) {
    padding: 0.75rem 1rem;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
  }
  .project-content :global(tr:hover td) { background: #f8fafc; }
</style>
