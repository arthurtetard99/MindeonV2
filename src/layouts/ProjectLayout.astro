---
import BaseLayout from './BaseLayout.astro';
import Illustration from '../components/ui/Illustration.astro';
import { formatDate } from '../utils/helpers';

interface RelatedEntry {
  slug: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  title: string;
  description: string;
  pathname: string;
  client?: string;
  date?: Date;
  tags?: string[];
  results?: string[];
  architectureType?: string;
  related?: RelatedEntry[];
}

const { title, description, pathname, client, date, tags = [], results = [], architectureType, related = [] } = Astro.props;

const tagColors = ['text-blue-700 bg-blue-50', 'text-violet-700 bg-violet-50', 'text-slate-600 bg-slate-100'];
const tagAccents = ['text-blue-700', 'text-violet-700', 'text-slate-600'];

function getIllustrationTopic(tags: string[]): string {
  const all = tags.map(t => t.toLowerCase()).join(' ');
  if (all.includes('voice') || all.includes('vapi') || all.includes('retell') || all.includes('vocal')) return 'voice';
  if (all.includes('whatsapp') || all.includes('chatbot') || all.includes('conversationnel') || all.includes('rag')) return 'chatbot';
  if (all.includes('webapp') || all.includes('full-stack') || all.includes('gestion commandes')) return 'webapp';
  if (all.includes('devis') || all.includes('pdf') || all.includes('pipeline b2b') || all.includes('qualification')) return 'devis';
  if (all.includes('crm') || all.includes('axonaut') || all.includes('fabrication') || all.includes('trello')) return 'crm';
  return 'workflow';
}

// Try to extract a short stat prefix from a result sentence
function extractStat(result: string): { stat: string; label: string } {
  const match = result.match(/^([+\-]?\d[\d\s%€hkKmM\/+\-.]*(?:\/\d+)?)/);
  if (match) {
    return { stat: match[1].trim(), label: result.slice(match[1].length).replace(/^[\s–—\-:]+/, '').trim() };
  }
  // No leading number — show first 4 words as stat, rest as label
  const words = result.split(' ');
  return { stat: words.slice(0, 3).join(' '), label: words.slice(3).join(' ') };
}

const illustrationTopic = getIllustrationTopic(tags);

const siteUrl = 'https://mindeon.ai';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Nos projets', item: `${siteUrl}/nos-projets/` },
    { '@type': 'ListItem', position: 3, name: title, item: `${siteUrl}${pathname}` },
  ],
};
const category = tags[0] ?? 'Cas client';
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  schemaType="article"
  datePublished={date?.toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <main class="pt-32">

    <!-- Hero -->
    <section class="max-w-7xl mx-auto px-6 mb-20">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">

        <!-- Left -->
        <div class="lg:w-7/12">
          <a
            href="/nos-projets/"
            class="inline-flex items-center gap-2 text-slate-500 hover:text-primary text-sm font-medium mb-8 transition-colors group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Tous les projets
          </a>

          <span class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-primary text-xs font-bold tracking-wider uppercase mb-6">
            Cas client
          </span>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-8 text-slate-900">
            {title}
          </h1>

          <!-- Meta grid -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 py-8 border-t border-slate-100">
            {client && (
              <div>
                <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Client</p>
                <p class="font-semibold text-slate-800 text-sm">{client}</p>
              </div>
            )}
            {date && (
              <div>
                <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Date</p>
                <time class="font-semibold text-slate-800 text-sm" datetime={date.toISOString()}>{formatDate(date)}</time>
              </div>
            )}
            {tags.length > 0 && (
              <div>
                <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Technologies</p>
                <p class="font-semibold text-slate-800 text-sm">{tags.slice(0, 3).join(', ')}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Right: illustration -->
        <div class="lg:w-5/12 w-full">
          <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(13,28,47,0.12)]">
            <Illustration topic={illustrationTopic} class="w-full h-full" />
          </div>
        </div>

      </div>
    </section>

    <!-- KPI strip -->
    {results.length > 0 && (
      <section class="bg-blue-50 py-12 mb-24" aria-label="Résultats obtenus">
        <div class="max-w-7xl mx-auto px-6">
          <div class={`grid grid-cols-1 gap-6 ${results.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
            {results.map((result) => {
              const { stat, label } = extractStat(result);
              return (
                <div class="bg-white p-8 rounded-2xl flex flex-col items-center text-center shadow-sm overflow-hidden">
                  <span class="text-3xl md:text-4xl font-black text-primary mb-3 leading-tight break-words w-full">{stat}</span>
                  <p class="text-sm font-medium text-slate-500 leading-relaxed">{label}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- Article content -->
    <div class="max-w-4xl mx-auto px-6 pb-24">
      <article class="project-content">
        <slot />
      </article>
    </div>

    <!-- Architecture diagram (injected from frontmatter) -->
    {architectureType === 'voicebot-retell' && (
      <div class="max-w-4xl mx-auto px-6 mb-16">
        <h2 class="text-2xl font-extrabold text-slate-900 mb-6 tracking-tight">Architecture technique</h2>
        <div class="relative rounded-2xl overflow-hidden arch-container">
          <div class="absolute right-0 bottom-0 w-48 h-48 rounded-full arch-blob"></div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 220" class="w-full block" aria-label="Architecture : Appel entrant → Retell AI → n8n → HubSpot + PDF → Email + Slack">
            <!-- Node 1: Appel entrant -->
            <rect x="10" y="50" width="150" height="90" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <path d="M71 72 c-.5 1-1.7 3.4-2 4.2-.3.8 0 1.7.7 2.1 1.5 1 3.2 2.3 4.8 3.8 1.6 1.6 2.8 3.3 3.8 4.8.5.8 1.3 1.1 2.1.8.8-.3 3.2-1.5 4.2-2 1-.5 1.3-1.8.8-2.8-.8-1.3-2-2.8-3.5-4.3-1.5-1.5-3-2.7-4.3-3.5-1-.6-2.3-.3-2.6.9z" fill="none" stroke="#7ca8ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="85" y="158" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">APPEL</text>
            <text x="85" y="172" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">ENTRANT</text>
            <!-- Arrow 1 -->
            <line x1="162" y1="95" x2="185" y2="95" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <polygon points="183,90 193,95 183,100" fill="rgba(255,255,255,0.25)"/>
            <!-- Node 2: Retell AI (highlighted) -->
            <rect x="195" y="50" width="150" height="90" rx="12" fill="rgba(37,99,235,0.25)" stroke="rgba(37,99,235,0.5)" stroke-width="1"/>
            <rect x="260" y="67" width="11" height="20" rx="5.5" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <path d="M253 83 q0 9 12.5 9 12.5 0 12.5-9" fill="none" stroke="#7ca8ff" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="265" y1="92" x2="265" y2="98" stroke="#7ca8ff" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="259" y1="98" x2="271" y2="98" stroke="#7ca8ff" stroke-width="1.5" stroke-linecap="round"/>
            <text x="270" y="158" text-anchor="middle" fill="#7ca8ff" font-family="Inter,sans-serif" font-size="10" font-weight="700" letter-spacing="1">RETELL AI</text>
            <text x="270" y="172" text-anchor="middle" fill="#7ca8ff" font-family="Inter,sans-serif" font-size="10" font-weight="700" letter-spacing="1">AGENT</text>
            <!-- Arrow 2 -->
            <line x1="347" y1="95" x2="370" y2="95" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <polygon points="368,90 378,95 368,100" fill="rgba(255,255,255,0.25)"/>
            <!-- Node 3: n8n -->
            <rect x="380" y="50" width="150" height="90" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <circle cx="440" cy="88" r="5" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <circle cx="458" cy="76" r="5" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <circle cx="458" cy="100" r="5" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <line x1="445" y1="85" x2="453" y2="79" stroke="#7ca8ff" stroke-width="1.5"/>
            <line x1="445" y1="91" x2="453" y2="97" stroke="#7ca8ff" stroke-width="1.5"/>
            <text x="455" y="158" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">N8N</text>
            <text x="455" y="172" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">WORKFLOW</text>
            <!-- Arrow 3 -->
            <line x1="532" y1="95" x2="555" y2="95" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <polygon points="553,90 563,95 553,100" fill="rgba(255,255,255,0.25)"/>
            <!-- Node 4: HubSpot + PDF -->
            <rect x="565" y="50" width="150" height="90" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <ellipse cx="640" cy="72" rx="13" ry="5" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <path d="M627 72 L627 92 Q627 97 640 97 Q653 97 653 92 L653 72" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <path d="M627 79 Q627 84 640 84 Q653 84 653 79" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <text x="640" y="158" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">HUBSPOT</text>
            <text x="640" y="172" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">+ DEVIS PDF</text>
            <!-- Arrow 4 -->
            <line x1="717" y1="95" x2="740" y2="95" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <polygon points="738,90 748,95 738,100" fill="rgba(255,255,255,0.25)"/>
            <!-- Node 5: Email + Slack -->
            <rect x="750" y="50" width="140" height="90" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <path d="M820 70 c-7 0-11 4-11 10 v9 l-3 3 v2 h28 v-2 l-3-3 v-9 c0-6-4-10-11-10z" fill="none" stroke="#7ca8ff" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M817 97 q0 3 3 3 t3-3" fill="none" stroke="#7ca8ff" stroke-width="1.5"/>
            <text x="820" y="158" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">EMAIL</text>
            <text x="820" y="172" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="Inter,sans-serif" font-size="10" font-weight="600" letter-spacing="1">+ SLACK</text>
          </svg>
        </div>
      </div>
    )}

    <!-- Projets similaires -->
    {related.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 pb-16" aria-labelledby="related-projects-heading">
        <h2 id="related-projects-heading" class="text-2xl font-extrabold text-slate-900 mb-8 tracking-tight">Projets similaires</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((item, i) => {
            const tag = item.tags?.[0] ?? 'Cas client';
            return (
              <a
                href={`/${item.slug}/`}
                class="group flex flex-col bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 overflow-hidden"
                aria-label={item.title}
              >
                <div class={`h-1.5 w-full ${i === 0 ? 'bg-primary' : i === 1 ? 'bg-violet-600' : 'bg-slate-400'}`}></div>
                <div class="p-6 flex flex-col flex-1">
                  <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4 self-start ${tagColors[i % 3]}`}>
                    {tag}
                  </span>
                  <h3 class="font-extrabold text-slate-900 text-base leading-snug mb-3 group-hover:text-primary transition-colors line-clamp-2">
                    {item.title}
                  </h3>
                  <p class="text-sm text-slate-500 leading-relaxed line-clamp-3 flex-1 mb-4">
                    {item.description}
                  </p>
                  <span class={`inline-flex items-center gap-1.5 text-sm font-bold ${tagAccents[i % 3]} group-hover:gap-3 transition-all duration-300`}>
                    Voir le projet
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="max-w-7xl mx-auto px-6 pb-24">
      <div class="bg-slate-50 rounded-2xl p-12 md:p-20 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-6">
          Prêt à automatiser vos workflows ?
        </h2>
        <p class="text-slate-500 mb-10 max-w-2xl mx-auto text-lg leading-relaxed">
          Découvrez comment nos solutions IA sur-mesure peuvent transformer votre efficacité opérationnelle et booster votre croissance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/"
            class="px-8 py-4 bg-primary hover:bg-blue-700 text-white rounded-xl font-bold transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.3)] hover:scale-[1.02] active:scale-95"
          >
            Parler à un expert
          </a>
          <a
            href="/nos-projets/"
            class="px-8 py-4 bg-white hover:bg-slate-100 text-slate-800 rounded-xl font-bold border border-slate-200 transition-all duration-200"
          >
            Voir d'autres projets
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .project-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .project-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .project-content :global(p) {
    color: #475569;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  .project-content :global(ul), .project-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #475569;
  }
  .project-content :global(li) {
    margin-bottom: 0.6rem;
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .project-content :global(ul > li) { list-style-type: disc; }
  .project-content :global(ol > li) { list-style-type: decimal; }
  .project-content :global(strong) { color: #0f172a; font-weight: 700; }
  .project-content :global(a) {
    color: #2563EB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .project-content :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .project-content :global(code:not(pre code)) {
    background: #f1f5f9;
    color: #2563EB;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .project-content :global(blockquote) {
    border-left: 3px solid #2563EB;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: #eff6ff;
    border-radius: 0 0.75rem 0.75rem 0;
    color: #334155;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .project-content :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }
  .project-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .project-content :global(th) {
    background: #f8fafc;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 700;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  .project-content :global(td) {
    padding: 0.75rem 1rem;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
  }
  .project-content :global(tr:hover td) { background: #f8fafc; }
  .project-content :global(.img-row) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 2rem 0;
  }
  .project-content :global(.img-row p) {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .project-content :global(.img-row img) {
    margin: 0;
    max-height: 700px;
    max-width: 100%;
    width: auto;
    height: auto;
    border: none;
    border-radius: 0.75rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .project-content :global(.img-row img:hover) {
    box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.4), 0 0 20px rgba(37, 99, 235, 0.3), 0 0 50px rgba(37, 99, 235, 0.15);
    transform: translateY(-2px);
  }
  @media (max-width: 640px) {
    .project-content :global(.img-row) {
      grid-template-columns: 1fr;
    }
  }
  .project-content :global(img) {
    max-width: 100%;
    height: auto;
    max-height: 600px;
    display: block;
    border-radius: 1rem;
    margin: 2rem auto;
    border: 1px solid #e2e8f0;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .project-content :global(img:hover) {
    box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.4), 0 0 20px rgba(37, 99, 235, 0.3), 0 0 50px rgba(37, 99, 235, 0.15);
    transform: translateY(-2px);
  }
</style>
