---
import SEOHead from '../components/seo/SEOHead.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pathname: string;
  ogImage?: string;
  schemaType?: 'organization' | 'article' | 'blogposting';
  datePublished?: string;
  author?: string;
}

const { title, description, pathname, ogImage, schemaType, datePublished, author } = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <SEOHead
      title={title}
      description={description}
      pathname={pathname}
      ogImage={ogImage}
      schemaType={schemaType}
      datePublished={datePublished}
      author={author}
    />
    <slot name="head" />
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="d7509ead-2675-4740-8df4-73110cbc59a2"></script>
  </head>
  <body class="font-sans bg-white text-slate-700 antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal script -->
    <script>
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach(el => {
        revealObserver.observe(el);
      });
    </script>
  </body>
</html>
