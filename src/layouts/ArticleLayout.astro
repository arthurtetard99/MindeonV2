---
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Illustration from '../components/ui/Illustration.astro';
import { formatDate } from '../utils/helpers';

interface Props {
  title: string;
  description: string;
  pathname: string;
  author?: string;
  date?: Date;
  tags?: string[];
}

const { title, description, pathname, author = 'Mindeon.ai', date, tags = [] } = Astro.props;

function getIllustrationTopic(tags: string[]): string {
  const all = tags.map(t => t.toLowerCase()).join(' ');
  if (all.includes('vapi') || all.includes('retell') || all.includes('voice bot') || all.includes('elevenlabs')) return 'voice';
  if (all.includes('rag') || all.includes('chatbot') || all.includes('base de connaissances')) return 'chatbot';
  if (all.includes('lead') || all.includes('qualification')) return 'lead';
  if (all.includes('roi') || all.includes('stratégie')) return 'roi';
  if (all.includes('mcp') || all.includes('gemini') || all.includes('llm') || all.includes('anthropic') || all.includes('claude') || (all.includes('agent') && !all.includes('lead'))) return 'ai';
  if (all.includes('make') || all.includes('zapier') || all.includes('comparatif')) return 'comparison';
  if (all.includes('n8n') || all.includes('automatisation')) return 'workflow';
  return 'workflow';
}
const illustrationTopic = getIllustrationTopic(tags);

// Estimate reading time
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  schemaType="blogposting"
  datePublished={date?.toISOString()}
  author={author}
>
  <!-- Hero header -->
  <section class="bg-white border-b border-slate-100 pt-12 pb-10">
    <div class="max-w-3xl mx-auto px-6">
      <a
        href="/articles/"
        class="inline-flex items-center gap-2 text-slate-500 hover:text-primary text-sm font-medium mb-6 transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Tous les articles
      </a>

      <!-- Tags as category -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {tags.map(tag => (
            <span class="bg-primary-light text-primary text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 leading-tight tracking-tight mb-5">
        {title}
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-8">{description}</p>

      <!-- Author + date -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-primary-light text-primary font-extrabold text-sm flex items-center justify-center" aria-hidden="true">
            {author === 'Mindeon.ai' ? 'M' : author.charAt(0)}
          </div>
          <div>
            <p class="font-semibold text-slate-700 text-sm leading-tight">{author}</p>
            {date && (
              <time class="text-xs text-slate-400" datetime={date.toISOString()}>{formatDate(date)}</time>
            )}
          </div>
        </div>
        <div class="w-px h-6 bg-slate-200" aria-hidden="true"></div>
        <div class="flex items-center gap-1.5 text-slate-400 text-xs">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          5 min de lecture
        </div>
      </div>
    </div>
  </section>

  <!-- Hero illustration -->
  <div class="max-w-3xl mx-auto px-6 -mt-0 mb-0">
    <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm" style="height: 280px;">
      <Illustration topic={illustrationTopic} class="w-full h-full" />
    </div>
  </div>

  <!-- Content + sidebar -->
  <div class="max-w-7xl mx-auto px-6 py-14 grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-14 items-start">

    <article class="article-content min-w-0">
      <slot />
    </article>

    <!-- Sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky top-28 space-y-6">

        <!-- Author card -->
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-primary-light text-primary font-extrabold flex items-center justify-center" aria-hidden="true">
              {author === 'Mindeon.ai' ? 'M' : author.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-slate-900 text-sm">{author}</p>
              <p class="text-xs text-slate-500">Mindeon.ai</p>
            </div>
          </div>
          <p class="text-xs text-slate-600 leading-relaxed">
            Agence d'IA et d'automatisation. On partage notre veille technologique chaque semaine.
          </p>
        </div>

        <!-- CTA -->
        <div class="bg-gradient-to-br from-blue-700 to-blue-900 rounded-2xl p-6 text-white">
          <p class="font-bold text-sm mb-2">Passez à l'action</p>
          <p class="text-blue-100 text-xs mb-4 leading-relaxed">30 min gratuites pour évaluer votre projet d'automatisation.</p>
          <a
            href="/contact/"
            class="block bg-white text-primary font-bold text-sm px-4 py-2.5 rounded-xl hover:bg-blue-50 transition-colors text-center"
          >
            Consultation gratuite →
          </a>
        </div>

        <!-- Share -->
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-5">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Partager</p>
          <div class="flex gap-2">
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=https://mindeon.ai${pathname}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-slate-200 text-slate-600 hover:text-primary hover:border-primary text-xs font-medium py-2 rounded-lg transition-colors"
              aria-label="Partager sur LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=https://mindeon.ai${pathname}&text=${encodeURIComponent(title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-slate-200 text-slate-600 hover:text-slate-900 hover:border-slate-400 text-xs font-medium py-2 rounded-lg transition-colors"
              aria-label="Partager sur Twitter/X"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.734-8.836L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter
            </a>
          </div>
        </div>
      </div>
    </aside>

  </div>

  <!-- Bottom CTA -->
  <section class="border-t border-slate-100 bg-slate-50 py-20">
    <div class="max-w-xl mx-auto px-6 text-center">
      <div class="w-14 h-14 rounded-2xl bg-primary-light text-primary flex items-center justify-center mx-auto mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">
        Envie d'implémenter l'IA dans votre entreprise ?
      </h2>
      <p class="text-slate-600 mb-8 leading-relaxed">
        Réservez 30 min avec notre équipe — on vous dit honnêtement si et comment l'IA peut vous aider.
      </p>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 shadow-[0_4px_14px_rgba(37,99,235,0.3)] hover:scale-[1.02] active:scale-95"
      >
        Réserver une consultation gratuite →
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .article-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    border-bottom: 2px solid #eff6ff;
    padding-bottom: 0.5rem;
  }
  .article-content :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content :global(p) {
    color: #475569;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #475569;
  }
  .article-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }
  .article-content :global(ul > li) { list-style-type: disc; }
  .article-content :global(ol > li) { list-style-type: decimal; }
  .article-content :global(strong) { color: #0f172a; font-weight: 700; }
  .article-content :global(a) {
    color: #2563EB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-content :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
    border: 1px solid #1e293b;
  }
  .article-content :global(code:not(pre code)) {
    background: #f1f5f9;
    color: #2563EB;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', monospace;
  }
  .article-content :global(blockquote) {
    border-left: 3px solid #2563EB;
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: #eff6ff;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #334155;
  }
  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .article-content :global(th) {
    background: #f8fafc;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 700;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  .article-content :global(td) {
    padding: 0.75rem 1rem;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
  }
  .article-content :global(tr:hover td) {
    background: #f8fafc;
  }
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }
</style>
