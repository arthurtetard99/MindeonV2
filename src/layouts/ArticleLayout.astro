---
import BaseLayout from './BaseLayout.astro';
import Illustration from '../components/ui/Illustration.astro';
import { formatDate } from '../utils/helpers';

interface RelatedEntry {
  slug: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  title: string;
  description: string;
  pathname: string;
  author?: string;
  date?: Date;
  tags?: string[];
  image?: string;
  related?: RelatedEntry[];
}

const { title, description, pathname, author = 'Mindeon.ai', date, tags = [], image, related = [] } = Astro.props;

const tagColors = ['text-blue-700 bg-blue-50', 'text-violet-700 bg-violet-50', 'text-slate-600 bg-slate-100'];
const tagAccents = ['text-blue-700', 'text-violet-700', 'text-slate-600'];

function getIllustrationTopic(tags: string[]): string {
  const all = tags.map(t => t.toLowerCase()).join(' ');
  if (all.includes('vapi') || all.includes('retell') || all.includes('voice bot') || all.includes('elevenlabs')) return 'voice';
  if (all.includes('rag') || all.includes('chatbot') || all.includes('base de connaissances')) return 'chatbot';
  if (all.includes('lead') || all.includes('qualification')) return 'lead';
  if (all.includes('roi') || all.includes('calcul') || all.includes('stratégie')) return 'roi';
  if (all.includes('mcp') || all.includes('gemini') || all.includes('llm') || all.includes('anthropic') || all.includes('claude') || (all.includes('agent') && !all.includes('lead'))) return 'ai';
  if (all.includes('make') || all.includes('zapier') || all.includes('comparatif')) return 'comparison';
  if (all.includes('n8n') || all.includes('automatisation')) return 'workflow';
  return 'workflow';
}
const illustrationTopic = getIllustrationTopic(tags);
const category = tags[0] ?? 'Article';

const siteUrl = 'https://mindeon.ai';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Articles', item: `${siteUrl}/articles/` },
    { '@type': 'ListItem', position: 3, name: title, item: `${siteUrl}${pathname}` },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  schemaType="blogposting"
  datePublished={date?.toISOString()}
  author={author}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-32 pb-20">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">

      <!-- Left: meta + title -->
      <div class="lg:w-7/12">
        <!-- Back link -->
        <a
          href="/articles/"
          class="inline-flex items-center gap-2 text-slate-500 hover:text-primary text-sm font-medium mb-8 transition-colors group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Tous les articles
        </a>

        <span class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-primary text-xs font-bold tracking-wider uppercase mb-6">
          {category}
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-8 text-slate-900">
          {title}
        </h1>

        <!-- Meta grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 py-8 border-t border-slate-100">
          <div>
            <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Auteur</p>
            <p class="font-semibold text-slate-800 text-sm">{author}</p>
          </div>
          {date && (
            <div>
              <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Date</p>
              <time class="font-semibold text-slate-800 text-sm" datetime={date.toISOString()}>{formatDate(date)}</time>
            </div>
          )}
          {tags.length > 1 && (
            <div>
              <p class="text-[10px] font-bold text-slate-600 tracking-widest uppercase mb-1">Thèmes</p>
              <p class="font-semibold text-slate-800 text-sm">{tags.slice(1, 3).join(', ')}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Right: illustration or custom image -->
      <div class="lg:w-5/12 w-full">
        <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(13,28,47,0.12)]">
          {image
            ? <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" />
            : <Illustration topic={illustrationTopic} class="w-full h-full" />
          }
        </div>
      </div>

    </div>
  </section>

  <!-- Article content + TOC -->
  <div class="max-w-5xl mx-auto px-6 pb-24">

    <!-- Mobile TOC (collapsible) -->
    <details class="lg:hidden mb-8 bg-slate-50 border border-slate-200 rounded-xl overflow-hidden">
      <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer font-semibold text-slate-800 text-sm list-none select-none">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="15" y1="12" y2="12"/><line x1="3" x2="18" y1="18" y2="18"/></svg>
          Sommaire
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-open:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </summary>
      <nav aria-label="Sommaire de l'article">
        <ol id="toc-mobile" class="px-5 py-3 space-y-1 text-sm"></ol>
      </nav>
    </details>

    <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-14 xl:gap-16">

      <!-- Desktop TOC sidebar -->
      <aside class="hidden lg:block" aria-label="Sommaire">
        <nav class="sticky top-24 max-h-[calc(70vh-6rem)] overflow-y-auto" aria-label="Sommaire de l'article">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Sommaire</p>
          <ol id="toc-desktop" class="space-y-0.5"></ol>
        </nav>
      </aside>

      <!-- Article -->
      <article class="article-content min-w-0">
        <slot />
      </article>

    </div>
  </div>

  <!-- Articles similaires -->
  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 pb-16" aria-labelledby="related-articles-heading">
      <h2 id="related-articles-heading" class="text-2xl font-extrabold text-slate-900 mb-8 tracking-tight">Articles similaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {related.map((item, i) => {
          const tag = item.tags?.[0] ?? 'IA';
          return (
            <a
              href={`/${item.slug}/`}
              class="group flex flex-col bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 overflow-hidden"
              aria-label={item.title}
            >
              <div class={`h-1.5 w-full ${i === 0 ? 'bg-primary' : i === 1 ? 'bg-violet-600' : 'bg-slate-400'}`}></div>
              <div class="p-6 flex flex-col flex-1">
                <span class={`text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4 self-start ${tagColors[i % 3]}`}>
                  {tag}
                </span>
                <h3 class="font-extrabold text-slate-900 text-base leading-snug mb-3 group-hover:text-primary transition-colors line-clamp-2">
                  {item.title}
                </h3>
                <p class="text-sm text-slate-500 leading-relaxed line-clamp-3 flex-1 mb-4">
                  {item.description}
                </p>
                <span class={`inline-flex items-center gap-1.5 text-sm font-bold ${tagAccents[i % 3]} group-hover:gap-3 transition-all duration-300`}>
                  Lire l'article
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="max-w-7xl mx-auto px-6 pb-24">
    <div class="bg-slate-50 rounded-2xl p-8 md:p-12 lg:p-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-6">
        Prêt à automatiser vos workflows ?
      </h2>
      <p class="text-slate-500 mb-10 max-w-2xl mx-auto text-lg leading-relaxed">
        Découvrez comment nos solutions IA sur-mesure peuvent transformer votre efficacité opérationnelle et booster votre croissance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact/"
          class="px-8 py-4 bg-primary hover:bg-blue-700 text-white rounded-xl font-bold transition-all duration-200 shadow-[0_4px_20px_rgba(37,99,235,0.3)] hover:scale-[1.02] active:scale-95"
        >
          Parler à un expert
        </a>
        <a
          href="/nos-projets/"
          class="px-8 py-4 bg-white hover:bg-slate-100 text-slate-800 rounded-xl font-bold border border-slate-200 transition-all duration-200"
        >
          Voir nos réalisations en agents IA
        </a>
      </div>
    </div>
  </section>

  <!-- Share strip -->
  <div class="border-t border-slate-100 py-8">
    <div class="max-w-3xl mx-auto px-6 flex items-center gap-4">
      <p class="text-xs font-bold text-slate-600 uppercase tracking-widest shrink-0">Partager</p>
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=https://mindeon.ai${pathname}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 bg-slate-50 border border-slate-200 text-slate-600 hover:text-primary hover:border-primary text-xs font-medium px-4 py-2 rounded-full transition-colors"
        aria-label="Partager sur LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <a
        href={`https://twitter.com/intent/tweet?url=https://mindeon.ai${pathname}&text=${encodeURIComponent(title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 bg-slate-50 border border-slate-200 text-slate-600 hover:text-slate-900 hover:border-slate-400 text-xs font-medium px-4 py-2 rounded-full transition-colors"
        aria-label="Partager sur Twitter/X"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.734-8.836L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Twitter / X
      </a>
    </div>
  </div>

</BaseLayout>

<script>
  const headings = document.querySelectorAll<HTMLElement>('.article-content h2, .article-content h3');
  const tocDesktop = document.getElementById('toc-desktop');
  const tocMobile  = document.getElementById('toc-mobile');

  if (headings.length > 1) {
    headings.forEach(heading => {
      const id = heading.id;
      if (!id) return;
      const isH3 = heading.tagName === 'H3';

      [tocDesktop, tocMobile].forEach(container => {
        if (!container) return;
        const li = document.createElement('li');
        const a  = document.createElement('a');
        a.href        = `#${id}`;
        a.textContent = heading.textContent ?? '';
        a.dataset.toc = id;
        a.className   = isH3
          ? 'toc-link block text-xs text-slate-500 hover:text-primary py-1 pl-3 border-l border-slate-200 hover:border-primary transition-all duration-150 leading-snug font-medium'
          : 'toc-link block text-sm text-slate-700 hover:text-primary py-1.5 pl-3 border-l-2 border-slate-200 hover:border-primary transition-all duration-150 leading-snug font-semibold';
        li.appendChild(a);
        container.appendChild(li);
      });
    });

    // Highlight active heading on scroll
    const visibleSet = new Set<string>();
    const headingIds = [...headings].map(h => h.id).filter(Boolean);

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) visibleSet.add(entry.target.id);
        else visibleSet.delete(entry.target.id);
      });
      const activeId = headingIds.find(id => visibleSet.has(id));
      document.querySelectorAll<HTMLAnchorElement>('.toc-link').forEach(a => {
        const isActive = a.dataset.toc === activeId;
        a.classList.toggle('toc-active', isActive);
      });
    }, { rootMargin: '-80px 0px -50% 0px', threshold: 0 });

    headings.forEach(h => { if (h.id) observer.observe(h); });
  } else {
    // Hide TOC elements if too few headings
    document.querySelectorAll<HTMLElement>('[id^="toc-"], details.lg\\:hidden').forEach(el => {
      el.style.display = 'none';
    });
    const aside = document.querySelector<HTMLElement>('aside');
    if (aside) aside.style.display = 'none';
  }
</script>

<style>
  .article-content :global(h2),
  .article-content :global(h3) {
    scroll-margin-top: 7rem;
  }

  .toc-link.toc-active {
    color: #2563EB;
    border-color: #2563EB;
    font-weight: 700;
  }

  .article-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .article-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content :global(p) {
    color: #475569;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #475569;
  }
  .article-content :global(li) {
    margin-bottom: 0.6rem;
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .article-content :global(ul > li) { list-style-type: disc; }
  .article-content :global(ol > li) { list-style-type: decimal; }
  .article-content :global(strong) { color: #0f172a; font-weight: 700; }
  .article-content :global(a) {
    color: #2563EB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-content :global(a[href="/contact/"]) {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    background: #2563EB;
    color: #fff !important;
    text-decoration: none !important;
    font-weight: 800;
    font-size: 0.95rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: 0.02em;
    padding: 0.35em 1.1em;
    border-radius: 999px;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    vertical-align: middle;
  }
  .article-content :global(a[href="/contact/"]::after) {
    content: '→';
    font-weight: 700;
    transition: transform 0.2s ease;
  }
  .article-content :global(a[href="/contact/"]:hover) {
    background: #1D4ED8;
    transform: scale(1.03);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.45);
  }
  .article-content :global(a[href="/contact/"]:hover::after) {
    transform: translateX(3px);
  }
  .article-content :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .article-content :global(code:not(pre code)) {
    background: #f1f5f9;
    color: #2563EB;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .article-content :global(blockquote) {
    border-left: 3px solid #2563EB;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: #eff6ff;
    border-radius: 0 0.75rem 0.75rem 0;
    color: #334155;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .article-content :global(th) {
    background: #f8fafc;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 700;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  .article-content :global(td) {
    padding: 0.75rem 1rem;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
  }
  .article-content :global(tr:hover td) { background: #f8fafc; }
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }
  .article-content :global(img) {
    border-radius: 0.75rem;
    margin: 2rem 0;
    width: 100%;
  }
</style>
